+  const cardShadow = flipped ? `0 0 60px ${meta.glow}, inset 0 0 40px ${meta.glow}` : stageStyle.boxShadow;
+
+  const finalLabel =
+    tier === "legendary" ? "⚡ LEGENDARY PULL ⚡" :
