+  const totalTaps = TAP_STAGES[tier];      // 0 = simple instant-reveal, 1/2/3 = escalation
+  const isSimple  = totalTaps === 0;
+
+  const [tapStage,          setTapStage]          = useState(0);
+  const [flipped,           setFlipped]           = useState(false);
+  const [showMythicSeq,     setShowMythicSeq]     = useState(false);
+  const [shakeScreen,       setShakeScreen]       = useState(false);
+  const [particleKey,       setParticleKey]       = useState(0); // forces remount on tap
+  const [boltKey,           setBoltKey]           = useState(0);
+
+  // current visual style is driven by how many taps have already landed
+  // (tapStage is incremented *after* the tap, so before first tap it shows stage-0 styling)
+  const stageStyle = getStageStyle(tapStage);
+
+  // ── particles (re-keyed on every tap so animation replays) ──
+  const particles = useMemo(() => Array.from({ length: 26 }, (_, i) => {
+    const angle = (i / 26) * Math.PI * 2 + Math.random() * 0.4;
+    const dist  = 120 + Math.random() * 200;
+    return {
+      x:     Math.cos(angle) * dist,
+      y:     Math.sin(angle) * dist,
+      delay: Math.random() * 0.35,
+      color: stageStyle.particleColors[i % 3],
+    };
+  }), [particleKey]); // eslint-disable-line react-hooks/exhaustive-deps
+
+  const bolts = useMemo(() => Array.from({ length: 6 }, (_, i) => ({
+    rot:   (i / 6) * 360 + Math.random() * 20,
+    delay: 0.04 + i * 0.07,
+  })), [boltKey]); // eslint-disable-line react-hooks/exhaustive-deps
+
+  // ── tap handler ──────────────────────────────────────────────
+  const handleTap = () => {
+    if (flipped) return;
+    setShakeScreen(true);
+    setTimeout(() => setShakeScreen(false), 420);
+    setParticleKey(k => k + 1);
+    if (stageStyle.showBolts) setBoltKey(k => k + 1);
+
+    const nextTap = tapStage + 1;
+
+    if (nextTap >= totalTaps) {
