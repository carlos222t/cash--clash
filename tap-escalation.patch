+// ─── Tap Escalation helpers ──────────────────────────────────
+// Epic:      1 tap  → purple aura + particles → flip reveal
+// Legendary: 2 taps → stage-0 purple → stage-1 golden + bolts → flip reveal
+// Mythic:    3 taps → stage-0 purple → stage-1 golden → stage-2 orange → MythicRevealSequence
+
+const TAP_STAGES = { common: 0, rare: 0, epic: 1, legendary: 2, mythic: 3 };
+
+function getStageStyle(stage) {
+  if (stage === 0) return {
+    border:      "2px solid #C77DFF",
+    boxShadow:   "0 0 60px rgba(199,125,255,0.75), inset 0 0 40px rgba(199,125,255,0.4)",
+    pulseColor:  "#C77DFF",
+    labelText:   "✧ TAP TO CHARGE ✧",
+    labelColor:  "#C77DFF",
+    showBolts:   false,
+    particleColors: ["#C77DFF","#9D4EDD","#FFFFFF"],
+  };
+  if (stage === 1) return {
+    border:      "2px solid #FFD96B",
+    boxShadow:   "0 0 80px rgba(255,217,107,0.85), inset 0 0 50px rgba(255,217,107,0.5)",
+    pulseColor:  "#FFD96B",
+    labelText:   "⚡ TAP AGAIN TO AWAKEN ⚡",
+    labelColor:  "#FFD96B",
+    showBolts:   true,
+    particleColors: ["#FFD96B","#B8973A","#FFF1B8"],
+  };
+  // stage 2 — mythic charge
+  return {
+    border:      "2px solid #FF6A2C",
+    boxShadow:   "0 0 100px rgba(255,106,44,0.9), inset 0 0 60px rgba(255,106,44,0.6)",
+    pulseColor:  "#FF6A2C",
+    labelText:   "◈ FINAL TAP ◈",
+    labelColor:  "#FF6A2C",
+    showBolts:   true,
+    particleColors: ["#FF6A2C","#FFD96B","#ffffff"],
+  };
+}

