    90%  { transform: translateY(-3px) rotate(0.2deg) scale(1.0); }
    100% { transform: translateY(0) rotate(0deg) scale(1); opacity: 1; }
  }

  /* Card dances/floats while waiting to be opened */
  @keyframes cpo-epic-dance {
    0%   { transform: translateY(0px) rotate(0deg) scale(1); }
    12%  { transform: translateY(-12px) rotate(-2.5deg) scale(1.02); }
    25%  { transform: translateY(-6px) rotate(1.5deg) scale(1.01); }
    37%  { transform: translateY(-16px) rotate(-1deg) scale(1.03); }
    50%  { transform: translateY(-4px) rotate(2deg) scale(1.01); }
    62%  { transform: translateY(-14px) rotate(-2deg) scale(1.02); }
    75%  { transform: translateY(-8px) rotate(1deg) scale(1.01); }
    87%  { transform: translateY(-18px) rotate(-1.5deg) scale(1.03); }
    100% { transform: translateY(0px) rotate(0deg) scale(1); }
  }

  /* Purple haze expands from crash point */
  @keyframes cpo-epic-haze-bloom {
    0%   { transform: translate(-50%, -50%) scale(0.1); opacity: 0; }
    20%  { opacity: 0.85; }
    60%  { transform: translate(-50%, -50%) scale(1); opacity: 0.65; }
    100% { transform: translate(-50%, -50%) scale(1); opacity: 0.65; }
  }

  /* Shockwave for epic crash */
  @keyframes cpo-epic-shockwave {
    0%   { transform: translate(-50%, -50%) scale(0.15); opacity: 1; }
    100% { transform: translate(-50%, -50%) scale(5); opacity: 0; }
  }

  /* White flash on crash */
  @keyframes cpo-epic-crash-flash {
    0%   { opacity: 0; }
    4%   { opacity: 0.7; }
    25%  { opacity: 0; }
    100% { opacity: 0; }
  }

  /* Rave laser beam rising from bottom */
  @keyframes cpo-epic-laser-rise {
    0%   { transform: scaleY(0) translateY(0); opacity: 0; transform-origin: bottom; }
    8%   { opacity: 1; }
    40%  { transform: scaleY(1) translateY(0); opacity: 0.85; transform-origin: bottom; }
    75%  { opacity: 0.6; }
    100% { opacity: 0.6; }
  }

  /* Laser sweep/sweep oscillation */
  @keyframes cpo-epic-laser-sweep {
    0%   { transform: rotate(var(--laser-start, 0deg)); }
    50%  { transform: rotate(var(--laser-end, 20deg)); }
    100% { transform: rotate(var(--laser-start, 0deg)); }
  }

  /* Laser beam pulse intensity */
  @keyframes cpo-epic-laser-pulse {
    0%,100% { opacity: 0.5; }
    50%     { opacity: 1; }
  }

  /* Purple haze ambient pulse */
  @keyframes cpo-epic-haze-pulse {
    0%,100% { opacity: 0.55; transform: translate(-50%, -50%) scale(1); }
    50%     { opacity: 0.8; transform: translate(-50%, -50%) scale(1.06); }
  }

  /* Card purple glow pulse while dancing */
  @keyframes cpo-epic-card-glow {
    0%,100% { box-shadow: 0 0 30px 8px rgba(199,125,255,0.5), 0 0 80px 20px rgba(150,50,220,0.3); }
    50%     { box-shadow: 0 0 60px 18px rgba(199,125,255,0.9), 0 0 140px 40px rgba(150,50,220,0.6); }
  }

  /* Crash floor impact ring */
  @keyframes cpo-epic-impact-ring {
    0%   { transform: translate(-50%, -50%) scale(0.2) scaleY(0.3); opacity: 0.9; }
    100% { transform: translate(-50%, -50%) scale(3.5) scaleY(0.3); opacity: 0; }
  }

  /* Reveal button pulsing glow */
  @keyframes cpo-epic-btn-pulse {
