    50%     { box-shadow: 0 0 28px rgba(199,125,255,0.9), 0 0 50px rgba(150,50,220,0.5); }
  }

  .cpo-pack-shake    { animation: cpo-pack-shake    0.55s ease-in-out infinite; }
  .cpo-pack-burst    { animation: cpo-pack-burst    0.7s ease-out forwards; }
  .cpo-card-flip     { animation: cpo-card-flip     0.7s cubic-bezier(0.2,0.9,0.3,1.2) both; }
  .cpo-glow-pulse    { animation: cpo-glow-pulse    2.4s ease-in-out infinite; }
  .cpo-float-up      { animation: cpo-float-up      0.5s ease-out both; }
  .cpo-vignette-in   { animation: cpo-vignette-in   0.4s ease-out both; }
  .cpo-screen-shake  { animation: cpo-screen-shake  0.4s ease-in-out; }
  .cpo-spin-slow     { animation: cpo-spin-slow 18s linear infinite; }

  @keyframes cpo-inspect-in {
    0%   { transform: scale(0.72); opacity: 0; }
    100% { transform: scale(1);    opacity: 1; }
  }
  .cpo-inspect-in    { animation: cpo-inspect-in 0.28s cubic-bezier(0.2,0.9,0.3,1.1) both; }
  .cpo-card-clickable { cursor: pointer; transition: transform 0.15s; }
  .cpo-card-clickable:hover { transform: scale(1.07) translateY(-3px); }

  @keyframes cpo-mythic-radiate {
    0%   { opacity: 0; transform: scale(0.85); }
    15%  { opacity: 1; transform: scale(1.08); }
    40%  { opacity: 1; transform: scale(1.0); }
