  @keyframes cpo-mythic-pulse-glow {
    0%,100% { box-shadow: 0 0 18px 4px rgba(120,0,180,0.55), 0 0 40px 8px rgba(80,0,140,0.35); }
    50%     { box-shadow: 0 0 38px 10px rgba(160,0,255,0.85), 0 0 80px 20px rgba(100,0,200,0.55); }
  }
  @keyframes cpo-mythic-screen-pulse {
    0%,100% { opacity: 0; }
    50%     { opacity: 0.09; }
