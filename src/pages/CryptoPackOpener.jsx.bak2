  @keyframes leg-glow-trail { 0%{opacity:0;transform:translate(-50%,-50%) translateY(-160vh) rotate(-35deg) scaleX(0.5)} 18%{opacity:0.9} 55%{opacity:0;transform:translate(-50%,-50%) translateY(28px) rotate(-4deg) scaleX(1)} 100%{opacity:0} }
  @keyframes leg-impact-shockwave { 0%{transform:translate(-50%,-50%) scale(0.1);opacity:1} 100%{transform:translate(-50%,-50%) scale(6);opacity:0} }
