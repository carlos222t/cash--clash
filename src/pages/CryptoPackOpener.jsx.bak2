  @keyframes cpo-mythic-glitch {
    0%,88%,100% { opacity: 0; transform: translateX(0); clip-path: inset(0 0 100% 0); }
    90%  { opacity: 1; transform: translateX(-5px); clip-path: inset(15% 0 35% 0); filter: hue-rotate(90deg) brightness(2.5); }
    92%  { opacity: 1; transform: translateX(6px);  clip-path: inset(55% 0 8%  0); filter: hue-rotate(200deg) brightness(3); }
    94%  { opacity: 1; transform: translateX(-3px); clip-path: inset(5%  0 65% 0); filter: hue-rotate(300deg) brightness(2); }
    96%  { opacity: 1; transform: translateX(0);    clip-path: inset(0 0 0 0);     filter: none; }
    98%  { opacity: 1; transform: translateX(3px);  clip-path: inset(25% 0 25% 0); filter: hue-rotate(60deg) brightness(2.5); }
  }
  @keyframes cpo-mythic-qqq {
    0%,88%,100% { opacity: 0; transform: translate(-50%,-50%) scale(0.6); }
    90%  { opacity: 1; transform: translate(-50%,-50%) scale(1.2); }
    95%  { opacity: 0.9; transform: translate(-50%,-50%) scale(1.0); }
    98%  { opacity: 0; transform: translate(-50%,-50%) scale(0.8); }
  }
  .cpo-mythic-radiate    { animation: cpo-mythic-radiate 3s cubic-bezier(0.2,0.8,0.2,1) both; }
  .cpo-mythic-pulse-glow { animation: cpo-mythic-pulse-glow 2.8s ease-in-out infinite; }

  /* ── RARE WAVE ANIMATIONS ── */

  /* The horizontal wave wipe — a tall glowing band sweeping left→right */
  @keyframes cpo-rare-wave-sweep {
    0%   { transform: translateX(-110%); }
    100% { transform: translateX(110vw); }
  }

  /* Screen tint that briefly brightens as wave passes */
  @keyframes cpo-rare-screen-tint {
    0%   { opacity: 0; }
    28%  { opacity: 0.22; }
    52%  { opacity: 0.28; }
    72%  { opacity: 0.12; }
    100% { opacity: 0; }
  }

  /* Card rides in from the left with the wave, easing to center */
  @keyframes cpo-rare-card-ride {
    0%   { transform: translateX(-80vw) rotate(-6deg) scale(0.85); opacity: 0; }
    18%  { opacity: 1; }
    68%  { transform: translateX(8px) rotate(1.5deg) scale(1.03); }
    80%  { transform: translateX(-4px) rotate(-0.5deg) scale(0.99); }
    90%  { transform: translateX(2px) rotate(0.2deg) scale(1.005); }
    100% { transform: translateX(0) rotate(0deg) scale(1); opacity: 1; }
  }

  /* Card glow that pulses once it settles */
  @keyframes cpo-rare-card-glow {
    0%,100% { box-shadow: 0 0 28px 6px rgba(74,158,232,0.45), 0 0 70px 14px rgba(40,120,200,0.25); }
    50%     { box-shadow: 0 0 55px 16px rgba(74,158,232,0.85), 0 0 120px 30px rgba(40,120,200,0.5); }
  }

  /* Trailing ripple lines left behind by the wave */
  @keyframes cpo-rare-ripple {
    0%   { transform: scaleX(0); opacity: 0.8; }
    60%  { transform: scaleX(1); opacity: 0.5; }
    100% { transform: scaleX(1); opacity: 0; }
  }

  /* Label float-in from below */
  @keyframes cpo-rare-label-in {
    0%   { transform: translateY(14px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  /* Continue button shimmer */
  @keyframes cpo-rare-btn-glow {
    0%,100% { box-shadow: 0 0 10px rgba(74,158,232,0.3); }
    50%     { box-shadow: 0 0 24px rgba(74,158,232,0.75), 0 0 48px rgba(40,120,200,0.4); }
  }
  @keyframes cpo-pack-shoot {
    0%   { transform: translateY(0) rotate(0deg) scale(1); }
    25%  { transform: translateY(-8px) rotate(-2deg) scale(1.04); }
    45%  { transform: translateY(-6px) rotate(2deg) scale(1.03); }
    60%  { transform: translateY(-12px) rotate(-1deg) scale(1.05); }
    75%  { transform: translateY(-200px) rotate(-4deg) scale(0.95); opacity: 1; }
    100% { transform: translateY(-140vh) rotate(-8deg) scale(0.85); opacity: 0; }
  }
  @keyframes cpo-ufo-lift {
    0%   { transform: translateY(0) rotate(0deg) scale(1); filter: brightness(1); }
    20%  { transform: translateY(-8px) rotate(-1deg) scale(1.02); filter: brightness(1.1); }
    40%  { transform: translateY(-20px) rotate(1.5deg) scale(1.03); filter: brightness(1.2); }
    60%  { transform: translateY(-40px) rotate(-1deg) scale(1.04); filter: brightness(1.4) drop-shadow(0 0 20px rgba(255,255,255,0.4)); }
    80%  { transform: translateY(-80px) rotate(2deg) scale(1.05); filter: brightness(1.6) drop-shadow(0 0 35px rgba(255,255,255,0.6)); }
    100% { transform: translateY(-160vh) rotate(-3deg) scale(0.7); filter: brightness(2) drop-shadow(0 0 60px rgba(255,255,255,0.9)); opacity: 0; }
  }
  @keyframes cpo-crash-down {
    0%   { transform: translateY(-130vh) rotate(8deg) scale(0.7); opacity: 0; }
    50%  { transform: translateY(18px) rotate(-3deg) scale(1.06); opacity: 1; }
    65%  { transform: translateY(-10px) rotate(1.5deg) scale(0.97); }
    78%  { transform: translateY(6px) rotate(-0.5deg) scale(1.02); }
    90%  { transform: translateY(-3px) rotate(0.2deg) scale(1.0); }
    100% { transform: translateY(0) rotate(0deg) scale(1); opacity: 1; }
  }
  @keyframes cpo-crash-impact {
    0%   { transform: translate(-50%,-50%) scale(0.1); opacity: 0.9; }
    100% { transform: translate(-50%,-50%) scale(5); opacity: 0; }
  }
  @keyframes cpo-crash-flash-white {
    0%   { opacity: 0; }
    5%   { opacity: 0.7; }
    35%  { opacity: 0; }
    100% { opacity: 0; }
  }
  @keyframes cpo-ufo-glow {
    0%,100% { box-shadow: 0 0 30px 8px rgba(255,255,255,0.2); }
    50%     { box-shadow: 0 0 80px 24px rgba(255,255,255,0.7), 0 0 160px 48px rgba(200,200,255,0.4); }
  }
  @keyframes cpo-ufo-lift {
    0%   { transform: translateY(0) rotate(0deg) scale(1); filter: brightness(1); }
    20%  { transform: translateY(-8px) rotate(-1deg) scale(1.02); filter: brightness(1.1); }
    40%  { transform: translateY(-20px) rotate(1.5deg) scale(1.03); filter: brightness(1.2); }
    60%  { transform: translateY(-40px) rotate(-1deg) scale(1.04); filter: brightness(1.4) drop-shadow(0 0 20px rgba(255,255,255,0.4)); }
    80%  { transform: translateY(-80px) rotate(2deg) scale(1.05); filter: brightness(1.6) drop-shadow(0 0 35px rgba(255,255,255,0.6)); }
    100% { transform: translateY(-160vh) rotate(-3deg) scale(0.7); filter: brightness(2) drop-shadow(0 0 60px rgba(255,255,255,0.9)); opacity: 0; }
  }
  @keyframes cpo-crash-down {
    0%   { transform: translateY(-130vh) rotate(8deg) scale(0.7); opacity: 0; }
    50%  { transform: translateY(18px) rotate(-3deg) scale(1.06); opacity: 1; }
    65%  { transform: translateY(-10px) rotate(1.5deg) scale(0.97); }
    78%  { transform: translateY(6px) rotate(-0.5deg) scale(1.02); }
    90%  { transform: translateY(-3px) rotate(0.2deg) scale(1.0); }
    100% { transform: translateY(0) rotate(0deg) scale(1); opacity: 1; }
  }
  @keyframes cpo-crash-impact {
    0%   { transform: translate(-50%,-50%) scale(0.1); opacity: 0.9; }
    100% { transform: translate(-50%,-50%) scale(5); opacity: 0; }
  }
  @keyframes cpo-crash-flash-white {
    0%   { opacity: 0; }
    5%   { opacity: 0.7; }
    35%  { opacity: 0; }
    100% { opacity: 0; }
  }
  @keyframes cpo-ufo-glow {
    0%,100% { box-shadow: 0 0 30px 8px rgba(255,255,255,0.2); }
    50%     { box-shadow: 0 0 80px 24px rgba(255,255,255,0.7), 0 0 160px 48px rgba(200,200,255,0.4); }
  }
  @keyframes cpo-mythic-zoom-away {
    0%   { transform: scale(1) translateZ(0) rotate(0deg); opacity: 1; filter: brightness(1); }
    20%  { transform: scale(0.92) rotate(-1deg); opacity: 1; filter: brightness(1.3); }
    50%  { transform: scale(0.5) rotate(2deg); opacity: 0.8; filter: brightness(1.8) drop-shadow(0 0 30px rgba(255,106,44,0.8)); }
    80%  { transform: scale(0.15) rotate(-3deg); opacity: 0.4; filter: brightness(2.5) drop-shadow(0 0 60px rgba(255,106,44,1)); }
    100% { transform: scale(0.02) rotate(5deg); opacity: 0; filter: brightness(3); }
  }
  @keyframes cpo-mythic-crash-in {
    0%   { transform: translateY(-140vh) rotate(-10deg) scale(0.6); opacity: 0; filter: brightness(2); }
    45%  { transform: translateY(22px) rotate(2deg) scale(1.08); opacity: 1; filter: brightness(1.3); }
    60%  { transform: translateY(-14px) rotate(-1.5deg) scale(0.96); filter: brightness(1); }
    73%  { transform: translateY(8px) rotate(0.8deg) scale(1.02); }
    84%  { transform: translateY(-4px) rotate(-0.3deg) scale(0.99); }
    100% { transform: translateY(0) rotate(0deg) scale(1); opacity: 1; filter: brightness(1); }
  }
  @keyframes cpo-mythic-zoom-flash {
    0%   { opacity: 0; }
    10%  { opacity: 0.8; }
    40%  { opacity: 0; }
    100% { opacity: 0; }
  }
  @keyframes cpo-twc-laser-rise {
    0%   { transform: scaleY(0); opacity: 0; transform-origin: bottom; }
    10%  { opacity: 1; }
    45%  { transform: scaleY(1); opacity: 0.9; transform-origin: bottom; }
    100% { opacity: 0.75; }
  }
  @keyframes cpo-twc-laser-sweep {
    0%   { transform: rotate(var(--ls, 0deg)); }
    50%  { transform: rotate(var(--le, 15deg)); }
    100% { transform: rotate(var(--ls, 0deg)); }
  }
  @keyframes cpo-twc-laser-pulse {
    0%,100% { opacity: 0.6; }
    50%     { opacity: 1; }
  }
  @keyframes cpo-twc-glitch {
    0%,100%  { clip-path: inset(0 0 0 0); transform: translate(0,0); filter: none; }
    10%  { clip-path: inset(12% 0 32% 0); transform: translate(-5px, 2px); filter: hue-rotate(90deg) brightness(2.5) saturate(3); }
    20%  { clip-path: inset(48% 0 6% 0);  transform: translate(7px, -3px); filter: hue-rotate(0deg) brightness(3) saturate(4); }
    30%  { clip-path: inset(6% 0 58% 0);  transform: translate(-4px, 4px); filter: hue-rotate(180deg) brightness(2); }
    40%  { clip-path: inset(0 0 0 0);     transform: translate(0,0); filter: none; }
    55%  { clip-path: inset(22% 0 22% 0); transform: translate(6px, -2px); filter: hue-rotate(45deg) brightness(2.8) saturate(3); }
    65%  { clip-path: inset(8% 0 42% 0);  transform: translate(-6px, 3px); filter: hue-rotate(330deg) brightness(3.2) saturate(4); }
    75%  { clip-path: inset(0 0 0 0);     transform: translate(0,0); filter: none; }
  }
  @keyframes cpo-twc-floor-glow {
    0%,100% { opacity: 0.4; }
    50%     { opacity: 0.7; }
  }
  @keyframes cpo-card-want-out {
    0%,100% { transform: rotate(0deg) translateX(0); }
    10%  { transform: rotate(-4deg) translateX(-4px); }
    20%  { transform: rotate(4deg) translateX(4px); }
    30%  { transform: rotate(-5deg) translateX(-5px); }
    40%  { transform: rotate(5deg) translateX(5px); }
    50%  { transform: rotate(-4deg) translateX(-4px); }
    60%  { transform: rotate(4deg) translateX(4px); }
    70%  { transform: rotate(-3deg) translateX(-3px); }
    80%  { transform: rotate(3deg) translateX(3px); }
    90%  { transform: rotate(-2deg) translateX(-2px); }
  }
  @keyframes cpo-pack-rip-shake {
    0%   { transform: rotate(0deg) scale(1); }
    15%  { transform: rotate(-4deg) scale(1.03) translateY(-6px); }
    30%  { transform: rotate(4deg) scale(1.05) translateY(-10px); }
    45%  { transform: rotate(-3deg) scale(1.04) translateY(-7px); }
    60%  { transform: rotate(5deg) scale(1.06) translateY(-12px); }
    75%  { transform: rotate(-2deg) scale(1.03) translateY(-5px); }
    100% { transform: rotate(0deg) scale(1); }
  }
  @keyframes cpo-pack-rip-top {
    0%   { transform: translateY(0) rotate(0deg); opacity: 1; }
    100% { transform: translateY(-130vh) rotate(-18deg); opacity: 0; }
  }
  @keyframes cpo-pack-rip-bottom {
    0%   { transform: translateY(0) rotate(0deg); opacity: 1; }
    100% { transform: translateY(130vh) rotate(10deg); opacity: 0; }
  }
  @keyframes cpo-card-shoot-up {
    0%   { transform: translateY(0) scale(1); opacity: 1; }
    30%  { opacity: 1; }
    100% { transform: translateY(-140vh) scale(0.8); opacity: 0; }
  }
  @keyframes cpo-rip-flash {
    0%   { opacity: 0; }
    8%   { opacity: 0.55; }
    100% { opacity: 0; }
  }

  /* ── Mobile: scale card scenes to fit phone screens ── */
  @media (max-width: 640px) {

    /* The full-screen card opening scenes (mythic/legendary/epic/common result) */
    .cpo-scene-wrap {
      transform-origin: center center;
    }

    /* Scale the 288x384 card down so it fits comfortably */
    .cpo-card-scene {
      transform: scale(0.78);
      transform-origin: center center;
    }

    /* The inspect/results grid after pack open */
    .cpo-inspect-in {
      max-width: 100% !important;
      padding: 0 12px !important;
    }

    /* Pack selection grid — tighter on mobile */
    .cpo-pack-grid {
      gap: 12px !important;
    }

    /* Reduce gap between card and buttons below it */
    .cpo-card-scene-col {
      gap: 14px !important;
    }

    /* Shrink "Open Me" text and reveal buttons so they fit under the scaled card */
    .cpo-float-up {
      font-size: 14px !important;
      padding: 10px 24px !important;
      letter-spacing: 0.1em !important;
    }

    /* Laser beams — clip to screen */
    .cpo-laser-wrap {
      overflow: hidden !important;
    }

    /* Result cards row — wrap on mobile */
    .cpo-results-row {
      flex-wrap: wrap !important;
      justify-content: center !important;
      gap: 10px !important;
    }
  }
`;

let cssInjected = false;
function injectCSS() {
  if (cssInjected) return;
  const style = document.createElement("style");
  style.textContent = CSS;
  document.head.appendChild(style);
  cssInjected = true;
}

// ─── Matrix Rain ─────────────────────────────────────────────
const MATRIX_CHARS = "アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789ABCDEF<>{}[]|/\\*#$%@!?~";

function MatrixRain() {
  const columns = 28;
  const chars = Array.from({ length: columns }, (_, i) => {
    const len = 8 + Math.floor(Math.random() * 12);
    const delay = Math.random() * 1.2;
    const dur = 1.4 + Math.random() * 1.0;
    const x = (i / columns) * 100;
    return { len, delay, dur, x, chars: Array.from({ length: len }, () => MATRIX_CHARS[Math.floor(Math.random() * MATRIX_CHARS.length)]) };
  });


  // Persist a card gain to Supabase
  const persistCard = async (cardId) => {
    if (!currentUser) return;
    const current = owned[cardId] || 0;
    const newQty = current + 1;
    const { error } = await supabase
      .from('user_card_collections')
      .upsert(
        { user_id: currentUser.id, card_id: cardId, quantity: newQty, updated_at: new Date().toISOString() },
        { onConflict: 'user_id,card_id' }
      );
    if (error) console.error('Failed to save card:', error);
  };
  return (
    <div style={{ position: "absolute", inset: 0, overflow: "hidden", pointerEvents: "none", zIndex: 2 }}>
      {chars.map((col, ci) => (
        <div
          key={ci}
          style={{
            position: "absolute",
            left: `${col.x}%`,
            top: 0,
            display: "flex",
            flexDirection: "column",
            alignItems: "center",
            animation: `cpo-matrix-fall ${col.dur}s linear ${col.delay}s both`,
          }}
        >
          {col.chars.map((ch, ri) => (
            <span
              key={ri}
              style={{
                fontFamily: "monospace",
                fontSize: ri === 0 ? 16 : 13,
                lineHeight: "1.4",
                color: ri === 0 ? "#AAFFAA" : ri < 3 ? "#33FF33" : "#00BB00",
                textShadow: ri === 0 ? "0 0 12px #00ff00, 0 0 24px #00cc00" : "0 0 6px #00aa00",
                opacity: 1 - ri / col.len,
                animation: `cpo-matrix-char-flicker ${0.08 + Math.random() * 0.15}s steps(1) ${Math.random() * 0.5}s infinite`,
              }}
            >
              {ch}
            </span>
          ))}
        </div>
      ))}
    </div>
  );
}

// ─── TWC Glitch Overlay ─────────────────────────────────────
function TWCGlitchOverlay() {
  const [glitching, setGlitching] = useState(false);
  useEffect(() => {
    const schedule = () => {
      const id = setTimeout(() => {
        setGlitching(true);
        setTimeout(() => { setGlitching(false); schedule(); }, 400);
      }, 1500 + Math.random() * 500);
      return id;
    };
    const id = schedule();
    return () => clearTimeout(id);
  }, []);
  if (!glitching) return null;
  return (
    <div style={{
      position: "fixed", left: "50%", top: "50%", zIndex: 15, pointerEvents: "none",
      transform: "translate(-50%, -50%)",
      width: 288, height: 384,
    }}>
      <img src="/cards/TotalWorldControl.png" alt=""
        style={{
          width: "100%", height: "100%", objectFit: "cover", borderRadius: 12,
          animation: "cpo-twc-glitch 0.38s steps(2) both",
        }}
      />
    </div>
  );
}

// ─── NEW Mythic Reveal Sequence ───────────────────────────────
function MythicRevealSequence({ card, onClose }) {
  const meta = RARITY_META["mythic"];

  const [blackFlash, setBlackFlash] = useState(1);
  const [showMatrix, setShowMatrix]   = useState(false);
  const [showCard, setShowCard]       = useState(false);
  const [crashed, setCrashed]         = useState(false);
  const [heartbeat, setHeartbeat]     = useState(false);
  const [glitching, setGlitching]     = useState(false);
  const [showQQQ, setShowQQQ]         = useState(false);
  const [showOpenMe, setShowOpenMe]   = useState(false);
  const [shockwave, setShockwave]     = useState(false);
  const [flipped, setFlipped]         = useState(false);
  const [showContinue, setShowContinue] = useState(false);

  useEffect(() => {
    const timers = [];
    const t = (fn, ms) => { const id = setTimeout(fn, ms); timers.push(id); };

    t(() => setBlackFlash(2), 350);
    t(() => setBlackFlash(0), 750);
    t(() => { setShowMatrix(true); }, 900);
    t(() => { setShowMatrix(false); setShowCard(true); }, 2300);
    t(() => { setShockwave(true); setTimeout(() => setShockwave(false), 800); }, 3000);
    t(() => { setCrashed(true); setHeartbeat(true); }, 3050);
    t(() => { setGlitching(true); }, 5100);
    t(() => setShowQQQ(true), 5200);
    t(() => { setGlitching(false); setShowQQQ(false); }, 5750);
    t(() => { setGlitching(true); }, 6600);
    t(() => setShowQQQ(true), 6700);
    t(() => { setGlitching(false); setShowQQQ(false); }, 7250);
    t(() => { setShowOpenMe(true); }, 7700);

    return () => timers.forEach(clearTimeout);
  }, []);

  const [mythicPhase, setMythicPhase] = useState('idle');
  const [showTWC, setShowTWC] = useState(false);

  const handleCardClick = () => {
    if (!showOpenMe || flipped || mythicPhase !== 'idle') return;
    setMythicPhase('zooming');
    setTimeout(() => setShowTWC(true), 900);
    setTimeout(() => {
      setMythicPhase('crashed');
      setFlipped(true);
      setTimeout(() => setShowContinue(true), 1000);
    }, 900);
  };

  useEffect(() => {
    const handler = (e) => {
      if (e.type === 'keydown' && e.code !== 'Space') return;
      if (e.type === 'keydown') e.preventDefault();
      if (showContinue) { onClose(); return; }
      if (showOpenMe && !flipped) { handleCardClick(); }
    };
    window.addEventListener('keydown', handler);
    window.addEventListener('pointerdown', handler);
    return () => { window.removeEventListener('keydown', handler); window.removeEventListener('pointerdown', handler); };
  }, [showOpenMe, flipped, showContinue]);

  useEffect(() => {
    const handler = (e) => {
      if (e.type === 'keydown' && e.code !== 'Space') return;
      if (e.type === 'keydown') e.preventDefault();
      if (showContinue) { onClose(); return; }
      if (showOpenMe && !flipped) { handleCardClick(); }
    };
    window.addEventListener('keydown', handler);
    window.addEventListener('pointerdown', handler);
    return () => { window.removeEventListener('keydown', handler); window.removeEventListener('pointerdown', handler); };
  }, [showOpenMe, flipped, showContinue]);

  return (
    <div style={{
      position: "fixed", inset: 0, zIndex: 9999,
      display: "flex", alignItems: "center", justifyContent: "center",
      background: "#000", overflow: "hidden",
    }}>
      {blackFlash > 0 && (
        <div style={{
          position: "absolute", inset: 0, zIndex: 50, pointerEvents: "none",
          background: "#000",
          animation: "cpo-mythic-blackflash 0.32s steps(1) both",
          opacity: 1,
        }} />
      )}
      <div style={{ position: "absolute", inset: 0, background: "radial-gradient(ellipse at center, #0a1a08 0%, #000000 70%)" }} />
      {showMatrix && (
        <div style={{ position: "absolute", inset: 0, zIndex: 5 }}>
          <MatrixRain />
          <div style={{ position: "absolute", inset: 0, background: "radial-gradient(ellipse at center, rgba(0,20,0,0.3) 0%, rgba(0,0,0,0.85) 70%)" }} />
        </div>
      )}
      {heartbeat && !flipped && (
        <div style={{
          position: "absolute", inset: 0, zIndex: 3, pointerEvents: "none",
          background: "radial-gradient(ellipse at center, rgba(255,0,0,0.35) 0%, transparent 65%)",
          animation: "cpo-red-screen-pulse 0.75s ease-in-out infinite",
        }} />
      )}
      {shockwave && (
        <>
          <div style={{ position: "absolute", left: "50%", top: "50%", zIndex: 8, width: 300, height: 300, borderRadius: "50%", border: "3px solid rgba(255,100,0,0.9)", animation: "cpo-shockwave 0.65s ease-out both", pointerEvents: "none" }} />
          <div style={{ position: "absolute", left: "50%", top: "50%", zIndex: 8, width: 300, height: 300, borderRadius: "50%", border: "2px solid rgba(255,200,0,0.6)", animation: "cpo-shockwave 0.65s ease-out 0.08s both", pointerEvents: "none" }} />
          <div style={{ position: "absolute", inset: 0, zIndex: 9, pointerEvents: "none", background: "rgba(255,140,0,0.25)", animation: "cpo-crash-flash 0.5s ease-out both" }} />
        </>
      )}
      {showCard && (
        <div className="cpo-card-scene-col" style={{ position: "relative", zIndex: 10, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", gap: 28, minHeight: "100vh" }}>
          <div
            onClick={handleCardClick}
            className="cpo-card-scene"
            style={{
              perspective: 1200,
              cursor: showOpenMe && !flipped ? "pointer" : "default",
              filter: showOpenMe && !flipped ? "drop-shadow(0 0 18px rgba(255,106,44,0.7))" : "none",
              transition: "filter 0.3s",
            }}
          >
            <div style={{
              position: "relative", width: 288, height: 384,
              transformStyle: "preserve-3d",
              transition: flipped ? "transform 0.75s cubic-bezier(0.2,0.9,0.3,1.1)" : "none",
              transform: flipped ? "rotateY(180deg)" : "rotateY(0deg)",
              animation: !crashed
                ? "cpo-mythic-crash 0.85s cubic-bezier(0.15,0.8,0.2,1) both"
                : showQQQ
                ? "cpo-card-want-out 0.08s ease-in-out infinite"
                : mythicPhase === 'zooming'
                ? "cpo-mythic-zoom-away 0.85s cubic-bezier(0.4,0,0.8,1) forwards"
                : mythicPhase === 'crashed'
                ? "cpo-mythic-crash-in 0.9s cubic-bezier(0.15,0.8,0.2,1) both"
                : undefined,
            }}>
              <div style={{
                position: "absolute", inset: 0, borderRadius: 12,
                backfaceVisibility: "hidden",
                border: "none",
                background: "linear-gradient(160deg, #1a1a22, #0c0c10)",
                overflow: "hidden",
                boxShadow: heartbeat && !flipped
                  ? undefined
                  : `0 0 60px ${meta.glow}, inset 0 0 40px ${meta.glow}`,
                ...(heartbeat && !flipped ? { animation: "cpo-heartbeat 0.75s ease-in-out infinite, cpo-mythic-border-pulse 0.75s ease-in-out infinite" } : {}),
              }}>
                <img src={showTWC ? "/cards/TotalWorldControl.png" : "/mythiccard.png"} alt="Mythic" style={{ width: "100%", height: "100%", objectFit: "cover", objectPosition: "center", borderRadius: 10, transition: "opacity 0.3s" }} />
                {glitching && (
                  <div style={{ position: "absolute", inset: 0, zIndex: 10, borderRadius: 12, overflow: "hidden", pointerEvents: "none" }}>
                    <div style={{ width: "100%", height: "100%", background: "linear-gradient(160deg, #1a1a22, #0c0c10)", animation: "cpo-card-glitch 0.62s steps(2) both" }} />
                  </div>
                )}
                {showQQQ && (
                  <div style={{
                    position: "absolute", inset: 0, zIndex: 20, borderRadius: 12,
                    animation: "cpo-card-want-out 0.08s ease-in-out infinite",
                    pointerEvents: "none",
                  }} />
                )}
              </div>
              <div style={{
                position: "absolute", inset: 0, borderRadius: 12,
                backfaceVisibility: "hidden",
                transform: "rotateY(180deg)",
                border: "none",
                background: "linear-gradient(160deg, #1a1a22, #0c0c10)",
                overflow: "hidden",
                boxShadow: `0 0 60px ${meta.glow}, inset 0 0 40px ${meta.glow}`,
              }}>
                <img src="/cards/TotalWorldControl.png" alt="Total World Control"
                  style={{ width: "100%", height: "100%", objectFit: "cover", objectPosition: "center", display: "block", borderRadius: 10 }} />
              </div>
            </div>
          </div>
          {mythicPhase === 'crashed' && (
            <>
              {/* crash flash */}
              <div style={{ position: "fixed", inset: 0, zIndex: 8, pointerEvents: "none", background: "rgba(255,80,20,0.35)", animation: "cpo-mythic-zoom-flash 0.5s ease-out both" }} />
              <div style={{ position: "fixed", left: "50%", top: "50%", zIndex: 8, width: 320, height: 320, borderRadius: "50%", border: "3px solid rgba(255,106,44,0.95)", animation: "cpo-crash-impact 0.75s ease-out both", pointerEvents: "none" }} />
              <div style={{ position: "fixed", left: "50%", top: "50%", zIndex: 8, width: 320, height: 320, borderRadius: "50%", border: "2px solid rgba(255,60,0,0.5)", animation: "cpo-crash-impact 0.75s ease-out 0.1s both", pointerEvents: "none" }} />
              {/* rave lasers */}
              <div style={{ position: "fixed", inset: 0, zIndex: 3, pointerEvents: "none", overflow: "hidden" }}>
                {[
                  { x:5,  a:-32, h:0,   ls:-32, le:-14, d:2.7, delay:0    },
                  { x:13, a:-20, h:15,  ls:-20, le:0,   d:3.1, delay:0.1  },
                  { x:22, a:-10, h:350, ls:-10, le:8,   d:2.8, delay:0.05 },
                  { x:33, a:0,   h:30,  ls:0,   le:14,  d:3.3, delay:0.18 },
                  { x:44, a:8,   h:0,   ls:8,   le:22,  d:2.6, delay:0.08 },
                  { x:55, a:-5,  h:20,  ls:-5,  le:12,  d:3.0, delay:0.22 },
                  { x:65, a:12,  h:350, ls:12,  le:28,  d:2.9, delay:0.04 },
                  { x:75, a:22,  h:15,  ls:22,  le:8,   d:3.2, delay:0.14 },
                  { x:84, a:32,  h:0,   ls:32,  le:16,  d:2.7, delay:0.2  },
                  { x:92, a:20,  h:30,  ls:20,  le:36,  d:3.4, delay:0.28 },
                ].map((l, i) => (
                  <div key={i} style={{
                    position: "absolute", bottom: 0, left: l.x + "%",
                    width: 3, height: "92vh",
                    transformOrigin: "bottom center",
                    transform: "rotate(" + l.a + "deg)",
                    background: "linear-gradient(to top, hsl(" + l.h + ",100%,60%) 0%, hsl(" + l.h + ",90%,55%) 25%, hsl(" + l.h + ",80%,45%) 60%, transparent 100%)",
                    boxShadow: "0 0 8px 2px hsl(" + l.h + ",100%,60%), 0 0 20px 4px hsl(" + l.h + ",80%,50%)",
                    animation: "cpo-twc-laser-rise 0.6s cubic-bezier(0.2,0.8,0.2,1) " + l.delay + "s both, cpo-twc-laser-sweep " + l.d + "s ease-in-out " + (l.delay+0.6) + "s infinite, cpo-twc-laser-pulse " + (l.d*0.7) + "s ease-in-out " + l.delay + "s infinite",
                    '--ls': l.ls + "deg",
                    '--le': l.le + "deg",
                  }} />
                ))}
                {/* floor glow */}
                <div style={{
                  position: "absolute", bottom: 0, left: 0, right: 0, height: 100,
                  background: "linear-gradient(to top, rgba(255,60,0,0.5) 0%, rgba(255,200,0,0.2) 50%, transparent 100%)",
                  animation: "cpo-twc-floor-glow 1.2s ease-in-out infinite",
                }} />
              </div>
              {/* card glitch overlay — every 1.5s */}
              <TWCGlitchOverlay />
            </>
          )}
          {showOpenMe && !flipped && (
            <div className="cpo-float-up" style={{
              fontFamily: "Georgia, serif", fontSize: 22, fontWeight: 700, color: "#FF6A2C",
              letterSpacing: "0.35em", textTransform: "uppercase", userSelect: "none",
              animation: "cpo-openme-flicker 1.8s ease-in-out infinite, cpo-float-up 0.5s ease-out both",
            }}>
              ◈ &nbsp;open me&nbsp; ◈
            </div>
          )}
        </div>
      )}
    </div>
  );
}

// ─── Rare Reveal Sequence ────────────────────────────────────
// Total duration: 2.5s
// Timeline:
//   0ms    → wave sweeps left→right (1.1s), card rides in behind the wave front
//   0ms    → screen tint pulses with the wave
//   1100ms → wave exits, card has settled in center, ripple lines fade
//   1150ms → label + glow-pulse begin
//   1200ms → "Continue" button fades in

function RareRevealSequence({ card, onClose }) {
  const meta = RARITY_META["rare"];
  const [showCard,     setShowCard]     = useState(false);
  const [showLabel,    setShowLabel]    = useState(false);
  const [showContinue, setShowContinue] = useState(false);
  const [settled,      setSettled]      = useState(false);

  useEffect(() => {
    const timers = [];
    const t = (fn, ms) => { const id = setTimeout(fn, ms); timers.push(id); };
    t(() => setShowCard(true),     0);
    t(() => { setShowLabel(true); setSettled(true); }, 1150);
    t(() => setShowContinue(true), 1200);
    return () => timers.forEach(clearTimeout);
  }, []);


  useEffect(() => {
    const handler = (e) => {
      if (e.type === 'keydown' && e.code !== 'Space') return;
      if (e.type === 'keydown') e.preventDefault();
      onClose();
    };
    if (!showContinue) return;
    window.addEventListener('keydown', handler);
    window.addEventListener('pointerdown', handler);
    return () => { window.removeEventListener('keydown', handler); window.removeEventListener('pointerdown', handler); };
  }, [showContinue]);
  // Three trailing ripple lines at staggered delays
  const ripples = [
    { top: "35%", delay: "0.18s", width: "55%" },
    { top: "50%", delay: "0.28s", width: "70%" },
    { top: "65%", delay: "0.38s", width: "45%" },
  ];

  return (
    <div style={{
      position: "fixed", inset: 0, zIndex: 9999,
      display: "flex", alignItems: "center", justifyContent: "center",
      background: "#06090f", overflow: "hidden",
    }}>
      {/* Deep blue ambient bg */}
      <div style={{ position: "absolute", inset: 0, background: "radial-gradient(ellipse at 50% 55%, #071828 0%, #06090f 70%)" }} />

      {/* Screen tint pulse with wave */}
      <div style={{
        position: "absolute", inset: 0, zIndex: 2, pointerEvents: "none",
        background: "linear-gradient(90deg, transparent 0%, rgba(74,158,232,0.18) 40%, rgba(120,190,255,0.28) 55%, rgba(74,158,232,0.18) 70%, transparent 100%)",
        animation: "cpo-rare-screen-tint 1.1s cubic-bezier(0.4,0,0.6,1) both",
      }} />

      {/* The wave — a tall glowing vertical band sweeping across */}
      <div style={{
        position: "absolute", top: 0, left: 0, zIndex: 6,
        width: "28vw", height: "100%", pointerEvents: "none",
        background: "linear-gradient(90deg, transparent 0%, rgba(74,158,232,0.08) 15%, rgba(120,200,255,0.55) 45%, rgba(180,225,255,0.85) 55%, rgba(120,200,255,0.55) 65%, rgba(74,158,232,0.08) 85%, transparent 100%)",
        boxShadow: "0 0 60px 20px rgba(74,158,232,0.4), inset 0 0 40px rgba(180,225,255,0.3)",
        animation: "cpo-rare-wave-sweep 1.1s cubic-bezier(0.4,0,0.55,1) both",
      }} />

      {/* Trailing ripple lines */}
      {ripples.map((r, i) => (
        <div key={i} style={{
          position: "absolute", left: "15%", zIndex: 3,
          top: r.top, width: r.width, height: 1,
          background: `linear-gradient(90deg, transparent, rgba(74,158,232,0.7), transparent)`,
          transformOrigin: "left center",
          animation: `cpo-rare-ripple 0.9s ease-out ${r.delay} both`,
          pointerEvents: "none",
        }} />
      ))}

      {/* Card */}
      {showCard && (
        <div style={{ position: "relative", zIndex: 10, display: "flex", flexDirection: "column", alignItems: "center", gap: 24 }}>

          {/* Label */}
          <div style={{
            textTransform: "uppercase", letterSpacing: "0.4em", fontSize: 12,
            fontWeight: 700, color: meta.color, textShadow: `0 0 20px ${meta.glow}`,
            opacity: showLabel ? 1 : 0,
            animation: showLabel ? "cpo-rare-label-in 0.4s ease-out both" : "none",
          }}>◈ Rare Pull ◈</div>

          {/* Card face — rides in with the wave */}
          <div style={{
            position: "relative", width: 288, height: 384, borderRadius: 12,
            border: `2px solid ${meta.color}`,
            background: "linear-gradient(160deg, #0d1a2e, #060c14)",
            overflow: "hidden",
            animation: settled
              ? "cpo-rare-card-glow 2.2s ease-in-out infinite"
              : "cpo-rare-card-ride 1.05s cubic-bezier(0.2,0.85,0.3,1) both, cpo-rare-card-glow 2.2s ease-in-out 1.1s infinite",
          }}>
            {/* Foil shimmer */}
            <div style={{ position: "absolute", inset: 0, opacity: 0.18, pointerEvents: "none", zIndex: 3,
              background: "linear-gradient(135deg, transparent 30%, rgba(180,220,255,0.4) 50%, transparent 70%)" }} />

            {/* Header bar */}
            <div style={{ position: "relative", zIndex: 4, display: "flex", justifyContent: "space-between", alignItems: "center",
              padding: "8px 12px 6px", background: "rgba(0,0,0,0.6)", borderBottom: `1px solid ${meta.color}55` }}>
              <span style={{ fontSize: 10, fontWeight: 800, textTransform: "uppercase", letterSpacing: "0.3em", color: meta.color }}>Rare</span>
              <span style={{ fontSize: 10, fontWeight: 700, color: "#556", textTransform: "uppercase", letterSpacing: "0.15em" }}>{card.series}</span>
            </div>

            {/* Image */}
            <div style={{ position: "relative", overflow: "hidden", width: "100%", height: "100%" }}>
              <img src={card.image} alt={card.name}
                style={{ width: "100%", height: "100%", objectFit: "cover", objectPosition: "center", display: "block", borderRadius: 10 }}
                onError={e => { e.currentTarget.style.display = "none"; e.currentTarget.parentElement.style.background = `linear-gradient(160deg, ${meta.color}22, #060c14)`; }}
              />
              
            </div>

          </div>

          {/* Continue button */}
          {showContinue && (
            <button
              onClick={onClose}
              style={{
                background: "transparent", border: `1px solid ${meta.color}`, color: meta.color,
                fontWeight: 700, fontSize: 14, padding: "12px 40px", borderRadius: 8,
                cursor: "pointer", letterSpacing: "0.2em", textTransform: "uppercase",
                animation: "cpo-rare-label-in 0.4s ease-out both, cpo-rare-btn-glow 2s ease-in-out 0.4s infinite",
                transition: "background 0.2s",
              }}
              onMouseEnter={e => { e.currentTarget.style.background = `rgba(74,158,232,0.12)`; }}
              onMouseLeave={e => { e.currentTarget.style.background = "transparent"; }}
            >
              Continue Trading
            </button>
          )}
        </div>
      )}
    </div>
  );
}


// ─── Legendary Reveal Sequence ───────────────────────────────
function LegendaryRevealSequence({ card, onClose }) {
  const meta = RARITY_META["legendary"];
  const [flashCount, setFlashCount] = useState(0);
  const [showMoon,   setShowMoon]   = useState(false);
  const [showCard,   setShowCard]   = useState(false);
  const [crashed,    setCrashed]    = useState(false);
  const [showImpact, setShowImpact] = useState(false);
  const [floating,   setFloating]   = useState(false);
  const [showReveal, setShowReveal] = useState(false);
  const [flipped,    setFlipped]    = useState(false);
  const [showContinue, setShowContinue] = useState(false);

  const stars = useMemo(() => Array.from({ length: 80 }, (_, i) => ({
    x: ((i * 137.5) % 100), y: ((i * 97.3) % 70),
    size: 1 + (i % 3), delay: (i * 0.07) % 3, dur: 1.8 + (i % 5) * 0.4,
  })), []);

  useEffect(() => {
    const timers = [];
    const t = (fn, ms) => { const id = setTimeout(fn, ms); timers.push(id); };
    t(() => setFlashCount(1), 0);
    t(() => setFlashCount(0), 220);
    t(() => setFlashCount(2), 380);
    t(() => setFlashCount(0), 600);
    t(() => setFlashCount(3), 750);
    t(() => setFlashCount(0), 970);
    t(() => setShowMoon(true), 1050);
    t(() => setShowCard(true), 1350);
    t(() => { setShowImpact(true); setTimeout(() => setShowImpact(false), 900); }, 2200);
    t(() => setCrashed(true), 2280);
    t(() => setFloating(true), 2450);
    t(() => setShowReveal(true), 2700);
    return () => timers.forEach(clearTimeout);
  }, []);

  const [revealPhase, setRevealPhase] = useState('idle'); // idle | lifting | crashing | done

  const handleReveal = () => {
    if (revealPhase !== 'idle') return;
    setRevealPhase('lifting');
    setFloating(false);
    setTimeout(() => {
      setRevealPhase('crashing');
      setTimeout(() => {
        setFlipped(true);
        setRevealPhase('done');
        setTimeout(() => setShowContinue(true), 900);
      }, 900);
    }, 1000);
  };

  useEffect(() => {
    const handler = (e) => {
      if (e.type === 'keydown' && e.code !== 'Space') return;
      if (e.type === 'keydown') e.preventDefault();
      if (showContinue) { onClose(); return; }
      if (showReveal && !flipped) { handleReveal(); }
    };
    window.addEventListener('keydown', handler);
    window.addEventListener('pointerdown', handler);
    return () => { window.removeEventListener('keydown', handler); window.removeEventListener('pointerdown', handler); };
  }, [showReveal, flipped, showContinue]);

  return (
    <div style={{ position: "fixed", inset: 0, zIndex: 9999, display: "flex", alignItems: "center", justifyContent: "center", background: "#000", overflow: "hidden" }}>
      {flashCount > 0 && (
        <div style={{ position: "absolute", inset: 0, zIndex: 60, pointerEvents: "none", background: "radial-gradient(ellipse at center, rgba(255,230,80,0.98) 0%, rgba(255,200,0,0.85) 55%, rgba(180,130,0,0.5) 100%)", animation: "leg-yellow-flash 0.22s ease-out both" }} />
      )}
      {showMoon && (
        <>
          <div style={{ position: "absolute", inset: 0, background: "radial-gradient(ellipse at 50% 30%, #0d0a20 0%, #050510 60%, #000 100%)", animation: "leg-moon-in 0.5s ease-out both" }} />
          <div style={{ position: "absolute", inset: 0, pointerEvents: "none", overflow: "hidden" }}>
            {stars.map((s, i) => (
              <div key={i} style={{ position: "absolute", left: s.x+"%", top: s.y+"%", width: s.size, height: s.size, borderRadius: "50%", background: "#fff", boxShadow: "0 0 "+(s.size*2)+"px rgba(255,255,200,0.8)", animation: "leg-stars-twinkle "+s.dur+"s ease-in-out "+s.delay+"s infinite" }} />
            ))}
          </div>
          <div style={{ position: "absolute", bottom: 0, left: 0, right: 0, height: "38%", background: "radial-gradient(ellipse at 50% 120%, #c8c8c8 0%, #a0a0a0 30%, #707070 60%, #404040 100%)", borderRadius: "50% 50% 0 0 / 18% 18% 0 0", boxShadow: "0 -4px 40px rgba(150,150,150,0.3)" }} />
          {[{left:"12%",bottom:"12%",size:40},{left:"30%",bottom:"6%",size:22},{left:"60%",bottom:"14%",size:55},{left:"78%",bottom:"8%",size:28},{left:"88%",bottom:"18%",size:18}].map((c,i) => (
            <div key={i} style={{ position: "absolute", left: c.left, bottom: c.bottom, width: c.size, height: c.size*0.4, borderRadius: "50%", border: "2px solid rgba(120,120,120,0.55)", boxShadow: "inset 0 3px 8px rgba(0,0,0,0.4)" }} />
          ))}
          <div style={{ position: "absolute", top: "8%", right: "10%", width: 64, height: 64, borderRadius: "50%", background: "radial-gradient(ellipse at 35% 30%, #4a9ef8 0%, #1a6abf 45%, #0a3060 80%, #051830 100%)", boxShadow: "0 0 20px rgba(74,158,248,0.4)", overflow: "hidden" }}>
            <div style={{ position: "absolute", top: "20%", left: "10%", width: "40%", height: "30%", borderRadius: "50%", background: "rgba(80,160,60,0.7)" }} />
            <div style={{ position: "absolute", top: "50%", left: "30%", width: "55%", height: "28%", borderRadius: "50%", background: "rgba(80,160,60,0.6)" }} />
            <div style={{ position: "absolute", inset: 0, borderRadius: "50%", background: "linear-gradient(135deg, rgba(255,255,255,0.18) 0%, transparent 60%)" }} />
          </div>
        </>
      )}
      {showCard && !crashed && (
        <div style={{ position: "absolute", left: "50%", top: "48%", width: 340, height: 700, background: "linear-gradient(to bottom, rgba(255,220,60,0.0) 0%, rgba(255,220,60,0.55) 30%, rgba(255,240,120,0.9) 70%, rgba(255,255,200,0.6) 100%)", filter: "blur(12px)", transformOrigin: "center bottom", pointerEvents: "none", zIndex: 8, animation: "leg-glow-trail 0.95s cubic-bezier(0.15,0.85,0.2,1) both" }} />
      )}
      {showImpact && (
        <>
          <div style={{ position: "absolute", left: "50%", top: "48%", zIndex: 15, width: 280, height: 280, borderRadius: "50%", border: "3px solid rgba(255,220,60,0.95)", animation: "leg-impact-shockwave 0.7s ease-out both", pointerEvents: "none" }} />
          <div style={{ position: "absolute", left: "50%", top: "48%", zIndex: 15, width: 280, height: 280, borderRadius: "50%", border: "2px solid rgba(255,180,0,0.6)", animation: "leg-impact-shockwave 0.7s ease-out 0.08s both", pointerEvents: "none" }} />
          <div style={{ position: "absolute", left: "50%", top: "50%", zIndex: 14, width: 360, height: 100, borderRadius: "50%", border: "2px solid rgba(255,220,60,0.7)", animation: "leg-dust-ring 0.65s ease-out both", pointerEvents: "none" }} />
          <div style={{ position: "absolute", inset: 0, zIndex: 16, pointerEvents: "none", background: "rgba(255,220,80,0.3)", animation: "leg-impact-flash 0.45s ease-out both" }} />
        </>
      )}
      {showCard && (
        <div className="cpo-card-scene-col" style={{ position: "relative", zIndex: 10, display: "flex", flexDirection: "column", alignItems: "center", gap: 28 }}>
          <div className="cpo-card-scene" style={{ perspective: 1200 }}>
            <div style={{ position: "relative", width: 288, height: 384, transformStyle: "preserve-3d", transition: flipped ? "transform 0.75s cubic-bezier(0.2,0.9,0.3,1.1)" : "none", transform: flipped ? "rotateY(180deg)" : "rotateY(0deg)", animation: !crashed ? "leg-star-trail 0.95s cubic-bezier(0.15,0.85,0.2,1) both" : revealPhase === 'lifting' ? "cpo-ufo-lift 1.0s cubic-bezier(0.4,0,0.6,1) forwards, cpo-ufo-glow 0.5s ease-in-out infinite" : revealPhase === 'crashing' ? "cpo-crash-down 0.85s cubic-bezier(0.15,0.8,0.2,1) both" : floating ? "leg-float-idle 3.6s ease-in-out infinite, leg-card-glow-pulse 2.4s ease-in-out infinite" : "leg-card-glow-pulse 2.4s ease-in-out infinite" }}>
              <div style={{ position: "absolute", inset: 0, borderRadius: 12, backfaceVisibility: "hidden", border: "none", overflow: "hidden", background: "linear-gradient(160deg, #1c1800, #0c0c10)", boxShadow: "0 0 50px "+meta.glow+", inset 0 0 35px "+meta.glow }}>
                <img src="/legendarycard.png" alt="Legendary" style={{ width: "100%", height: "100%", objectFit: "cover", objectPosition: "center", borderRadius: 10 }} />
              </div>
              <div style={{ position: "absolute", inset: 0, borderRadius: 12, backfaceVisibility: "hidden", transform: "rotateY(180deg)", border: "none", background: "linear-gradient(160deg, #1c1800, #0c0c10)", overflow: "hidden", boxShadow: "0 0 60px "+meta.glow+", inset 0 0 40px "+meta.glow }}>
                <div style={{ position: "relative", overflow: "hidden", width: "100%", height: "100%" }}>
                  <img src={card.image} alt={card.name} style={{ width: "100%", height: "100%", objectFit: "cover", objectPosition: "center", display: "block", borderRadius: 10 }} onError={e => { e.currentTarget.style.display="none"; e.currentTarget.parentElement.style.background="linear-gradient(160deg, "+meta.color+"22, #0c0c10)"; }} />
                  
                </div>
              </div>
            </div>
          </div>
          {revealPhase === 'crashing' && (
            <>
              <div style={{ position: "fixed", inset: 0, zIndex: 9, pointerEvents: "none", background: "rgba(255,240,180,0.25)", animation: "cpo-crash-flash-white 0.5s ease-out both" }} />
              <div style={{ position: "fixed", left: "50%", top: "50%", zIndex: 9, width: 300, height: 300, borderRadius: "50%", border: "3px solid rgba(255,220,60,0.9)", animation: "cpo-crash-impact 0.7s ease-out both", pointerEvents: "none" }} />
              <div style={{ position: "fixed", left: "50%", top: "50%", zIndex: 9, width: 300, height: 300, borderRadius: "50%", border: "2px solid rgba(255,180,0,0.5)", animation: "cpo-crash-impact 0.7s ease-out 0.1s both", pointerEvents: "none" }} />
            </>
          )}
          {showReveal && !flipped && revealPhase === 'idle' && (
            <button className="cpo-float-up" onClick={handleReveal} style={{ background: "linear-gradient(135deg, #c9a84c, #7a5e22)", border: "1px solid #FFD96B", color: "#0c0c10", fontWeight: 700, fontSize: 15, padding: "13px 38px", borderRadius: 8, cursor: "pointer", letterSpacing: "0.15em", textTransform: "uppercase", animation: "leg-btn-pulse 1.8s ease-in-out infinite", transition: "transform 0.15s" }} onMouseEnter={e => e.currentTarget.style.transform="scale(1.05)"} onMouseLeave={e => e.currentTarget.style.transform="scale(1)"}>Reveal Card</button>
          )}
          {showContinue && (
            <button className="cpo-float-up" onClick={onClose} style={{ background: "transparent", border: "1px solid #FFD96B", color: "#FFD96B", fontWeight: 700, fontSize: 14, padding: "12px 40px", borderRadius: 8, cursor: "pointer", letterSpacing: "0.2em", textTransform: "uppercase", transition: "all 0.2s", boxShadow: "0 0 12px rgba(255,217,107,0.3)" }} onMouseEnter={e => { e.currentTarget.style.background="rgba(255,217,107,0.12)"; e.currentTarget.style.boxShadow="0 0 24px rgba(255,217,107,0.6)"; }} onMouseLeave={e => { e.currentTarget.style.background="transparent"; e.currentTarget.style.boxShadow="0 0 12px rgba(255,217,107,0.3)"; }}>Continue Trading</button>
          )}
        </div>
      )}
    </div>
  );
}

// ─── Epic Reveal Sequence (NEW) ───────────────────────────────
// Timeline:
//   0ms     → card crashes from top
//   600ms   → shockwave + flash
//   650ms   → purple haze blooms
//   800ms   → rave lasers shoot up from bottom
//   900ms   → card starts dancing
//   → user clicks "Reveal Card" button → card flips to reveal face

const EPIC_LASERS = [
  { x: 8,  angle: -28, hue: 270, delay: 0,    sweepStart: -28, sweepEnd: -12, dur: 2.8 },
  { x: 18, angle: -18, hue: 285, delay: 0.12, sweepStart: -18, sweepEnd:  2,  dur: 3.1 },
  { x: 30, angle: -8,  hue: 260, delay: 0.06, sweepStart:  -8, sweepEnd:  8,  dur: 2.6 },
  { x: 42, angle:  2,  hue: 300, delay: 0.18, sweepStart:   2, sweepEnd: 15,  dur: 3.4 },
  { x: 55, angle: -4,  hue: 275, delay: 0.09, sweepStart:  -4, sweepEnd: 10,  dur: 2.9 },
  { x: 65, angle:  10, hue: 290, delay: 0.22, sweepStart:  10, sweepEnd: 24,  dur: 3.2 },
  { x: 75, angle:  20, hue: 265, delay: 0.04, sweepStart:  20, sweepEnd:  6,  dur: 2.7 },
  { x: 85, angle:  30, hue: 310, delay: 0.15, sweepStart:  30, sweepEnd: 14,  dur: 3.0 },
  { x: 93, angle:  22, hue: 280, delay: 0.28, sweepStart:  22, sweepEnd: 38,  dur: 3.3 },
];

function EpicRevealSequence({ card, onClose }) {
  const meta = RARITY_META["epic"];

  const [showCard,      setShowCard]      = useState(false);
  const [crashed,       setCrashed]       = useState(false);
  const [showHaze,      setShowHaze]      = useState(false);
  const [showLasers,    setShowLasers]    = useState(false);
  const [dancing,       setDancing]       = useState(false);
  const [showShockwave, setShowShockwave] = useState(false);
  const [showFlash,     setShowFlash]     = useState(false);
  const [flipped,       setFlipped]       = useState(false);
  const [showContinue,  setShowContinue]  = useState(false);

  useEffect(() => {
    const timers = [];
    const t = (fn, ms) => { const id = setTimeout(fn, ms); timers.push(id); return id; };

    t(() => setShowCard(true), 0);
    t(() => { setShowShockwave(true); setShowFlash(true); setTimeout(() => setShowShockwave(false), 900); setTimeout(() => setShowFlash(false), 400); }, 600);
    t(() => { setCrashed(true); setShowHaze(true); }, 650);
    t(() => setShowLasers(true), 800);
    t(() => setDancing(true), 900);

    return () => timers.forEach(clearTimeout);
  }, []);

  const [revealPhase, setRevealPhase] = useState('idle');
  const [showCardFace, setShowCardFace] = useState(false);

  const handleReveal = () => {
    if (revealPhase !== 'idle') return;
    setRevealPhase('lifting');
    setDancing(false);
    setTimeout(() => setShowCardFace(true), 900);
    setTimeout(() => {
      setRevealPhase('crashing');
      setTimeout(() => {
        setFlipped(true);
        setRevealPhase('done');
        setTimeout(() => setShowContinue(true), 800);
      }, 900);
    }, 1000);
  };

  useEffect(() => {
    const handler = (e) => {
      if (e.type === 'keydown' && e.code !== 'Space') return;
      if (e.type === 'keydown') e.preventDefault();
      if (showContinue) { onClose(); return; }
      if (dancing && !flipped) { handleReveal(); }
    };
    window.addEventListener('keydown', handler);
    window.addEventListener('pointerdown', handler);
    return () => { window.removeEventListener('keydown', handler); window.removeEventListener('pointerdown', handler); };
  }, [dancing, flipped, showContinue]);

  return (
    <div style={{
      position: "fixed", inset: 0, zIndex: 9999,
      display: "flex", alignItems: "center", justifyContent: "center",
      background: "#08060e", overflow: "hidden",
    }}>

      {/* Deep purple ambient bg */}
      <div style={{ position: "absolute", inset: 0, background: "radial-gradient(ellipse at 50% 60%, #1a0a2e 0%, #08060e 70%)" }} />

      {/* Crash flash */}
      {showFlash && (
        <div style={{
          position: "absolute", inset: 0, zIndex: 30, pointerEvents: "none",
          background: "rgba(220,180,255,0.55)",
          animation: "cpo-epic-crash-flash 0.35s ease-out both",
        }} />
      )}

      {/* Purple haze bloom — large radial centered behind card */}
      {showHaze && (
        <div style={{
          position: "absolute", left: "50%", top: "48%", zIndex: 2,
          width: 700, height: 700, borderRadius: "50%",
          background: "radial-gradient(ellipse at center, rgba(160,60,255,0.55) 0%, rgba(100,20,200,0.3) 40%, transparent 72%)",
          pointerEvents: "none",
          animation: flipped
            ? "cpo-epic-haze-pulse 3s ease-in-out infinite"
            : "cpo-epic-haze-bloom 0.7s cubic-bezier(0.2,0.8,0.2,1) both, cpo-epic-haze-pulse 3s ease-in-out 0.7s infinite",
        }} />
      )}

      {/* Shockwave rings */}
      {showShockwave && (
        <>
          <div style={{ position: "absolute", left: "50%", top: "50%", zIndex: 8, width: 260, height: 120, borderRadius: "50%", border: "3px solid rgba(199,125,255,0.9)", animation: "cpo-epic-impact-ring 0.7s ease-out both", pointerEvents: "none" }} />
          <div style={{ position: "absolute", left: "50%", top: "50%", zIndex: 8, width: 260, height: 120, borderRadius: "50%", border: "2px solid rgba(150,80,255,0.6)", animation: "cpo-epic-impact-ring 0.7s ease-out 0.09s both", pointerEvents: "none" }} />
          <div style={{ position: "absolute", left: "50%", top: "50%", zIndex: 8, width: 400, height: 400, borderRadius: "50%", border: "1px solid rgba(199,125,255,0.4)", animation: "cpo-epic-shockwave 0.8s ease-out both", pointerEvents: "none" }} />
        </>
      )}

      {/* Rave lasers — rising from bottom */}
      {showLasers && !flipped && (
        <div style={{ position: "absolute", inset: 0, zIndex: 3, pointerEvents: "none", overflow: "hidden" }}>
          {EPIC_LASERS.map((laser, i) => (
            <div
              key={i}
              style={{
                position: "absolute",
                bottom: 0,
                left: `${laser.x}%`,
                width: 3,
                height: "90vh",
                transformOrigin: "bottom center",
                transform: `rotate(${laser.angle}deg)`,
                animation: `cpo-epic-laser-rise 0.5s cubic-bezier(0.2,0.8,0.2,1) ${laser.delay}s both, cpo-epic-laser-sweep ${laser.dur}s ease-in-out ${laser.delay + 0.5}s infinite, cpo-epic-laser-pulse ${laser.dur * 0.7}s ease-in-out ${laser.delay}s infinite`,
                background: `linear-gradient(to top, hsl(${laser.hue},100%,70%) 0%, hsl(${laser.hue},90%,60%) 20%, hsl(${laser.hue},80%,50%) 55%, transparent 100%)`,
                boxShadow: `0 0 8px 2px hsl(${laser.hue},100%,65%), 0 0 20px 4px hsl(${laser.hue},80%,50%)`,
                '--laser-start': `${laser.sweepStart}deg`,
                '--laser-end': `${laser.sweepEnd}deg`,
              }}
            />
          ))}
          {/* Laser floor glow */}
          <div style={{
            position: "absolute", bottom: 0, left: 0, right: 0, height: 120,
            background: "linear-gradient(to top, rgba(160,60,255,0.45) 0%, rgba(120,30,220,0.2) 50%, transparent 100%)",
            pointerEvents: "none",
          }} />
        </div>
      )}

      {/* Card */}
      {showCard && (
        <div style={{ position: "relative", zIndex: 10, display: "flex", flexDirection: "column", alignItems: "center", gap: 28 }}>

          {/* 3-D flip container */}
          <div className="cpo-card-scene" style={{ perspective: 1200 }}>
            <div style={{
              position: "relative", width: 288, height: 384,
              transformStyle: "preserve-3d",
              transition: flipped ? "transform 0.75s cubic-bezier(0.2,0.9,0.3,1.1)" : "none",
              transform: flipped ? "rotateY(180deg)" : "rotateY(0deg)",
              animation: !crashed
                ? "cpo-epic-crash 0.75s cubic-bezier(0.15,0.85,0.2,1) both"
                : revealPhase === 'lifting'
                ? "cpo-ufo-lift 1.0s cubic-bezier(0.4,0,0.6,1) forwards, cpo-ufo-glow 0.5s ease-in-out infinite"
                : revealPhase === 'crashing'
                ? "cpo-crash-down 0.85s cubic-bezier(0.15,0.8,0.2,1) both"
                : dancing
                ? "cpo-epic-dance 3.2s ease-in-out infinite, cpo-epic-card-glow 2.4s ease-in-out infinite"
                : "cpo-epic-card-glow 2.4s ease-in-out infinite",
            }}>

              {/* BACK FACE */}
              <div style={{
                position: "absolute", inset: 0, borderRadius: 12,
                backfaceVisibility: "hidden",
                border: "none",
                background: "linear-gradient(160deg, #1a0a2e, #0c0610)",
                overflow: "hidden",
                boxShadow: `0 0 50px ${meta.glow}, inset 0 0 35px ${meta.glow}`,
              }}>
                <img src={showCardFace ? card.image : "/epiccard.png"} alt="Epic" style={{ width: "100%", height: "100%", objectFit: "cover", objectPosition: "center", borderRadius: 10, transition: "opacity 0.3s" }} />
              </div>

              {/* FRONT FACE */}
              <div style={{
                position: "absolute", inset: 0, borderRadius: 12,
                backfaceVisibility: "hidden",
                transform: "rotateY(180deg)",
                border: "none",
                background: "linear-gradient(160deg, #1a0a2e, #0c0610)",
                overflow: "hidden",
                boxShadow: `0 0 60px ${meta.glow}, inset 0 0 40px ${meta.glow}`,
              }}>
                <div style={{ position: "absolute", inset: 0, opacity: 0.15, pointerEvents: "none", zIndex: 3, background: "linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.35) 50%, transparent 70%)" }} />
                <div style={{ position: "relative", overflow: "hidden", width: "100%", height: "100%" }}>
                  <img src={card.image} alt={card.name}
                    style={{ width: "100%", height: "100%", objectFit: "cover", objectPosition: "center", display: "block", borderRadius: 10 }}
                    onError={e => { e.currentTarget.style.display = "none"; e.currentTarget.parentElement.style.background = `linear-gradient(160deg, ${meta.color}22, #0c0c10)`; }}
                  />
                  
                </div>
              </div>

            </div>
          </div>

          {revealPhase === 'crashing' && (
            <>
              <div style={{ position: "fixed", inset: 0, zIndex: 9, pointerEvents: "none", background: "rgba(220,180,255,0.3)", animation: "cpo-crash-flash-white 0.5s ease-out both" }} />
              <div style={{ position: "fixed", left: "50%", top: "50%", zIndex: 9, width: 300, height: 300, borderRadius: "50%", border: "3px solid rgba(199,125,255,0.9)", animation: "cpo-crash-impact 0.7s ease-out both", pointerEvents: "none" }} />
              <div style={{ position: "fixed", left: "50%", top: "50%", zIndex: 9, width: 300, height: 300, borderRadius: "50%", border: "2px solid rgba(150,80,255,0.5)", animation: "cpo-crash-impact 0.7s ease-out 0.1s both", pointerEvents: "none" }} />
            </>
          )}
          {/* Reveal button — shown once card is dancing */}
          {dancing && !flipped && revealPhase === 'idle' && (
            <button
              className="cpo-float-up"
              onClick={handleReveal}
              style={{
                background: "linear-gradient(135deg, #9d4edd, #6a00cc)",
                border: "1px solid #C77DFF",
                color: "#f0ece0",
                fontWeight: 700, fontSize: 15, padding: "13px 38px", borderRadius: 8,
                cursor: "pointer", letterSpacing: "0.15em", textTransform: "uppercase",
                animation: "cpo-epic-btn-pulse 1.8s ease-in-out infinite",
                transition: "transform 0.15s",
              }}
              onMouseEnter={e => e.currentTarget.style.transform = "scale(1.05)"}
              onMouseLeave={e => e.currentTarget.style.transform = "scale(1)"}
            >
              ✦ Reveal Card
            </button>
          )}

          {/* Continue button after flip */}
          {showContinue && (
            <button
              className="cpo-float-up"
              onClick={onClose}
              style={{
                background: "transparent", border: "1px solid #C77DFF", color: "#C77DFF",
                fontWeight: 700, fontSize: 14, padding: "12px 40px", borderRadius: 8,
                cursor: "pointer", letterSpacing: "0.2em", textTransform: "uppercase",
                transition: "all 0.2s", boxShadow: "0 0 12px rgba(199,125,255,0.3)",
                animationDelay: "0.5s",
              }}
              onMouseEnter={e => { e.currentTarget.style.background = "rgba(199,125,255,0.12)"; e.currentTarget.style.boxShadow = "0 0 24px rgba(199,125,255,0.6)"; }}
              onMouseLeave={e => { e.currentTarget.style.background = "transparent"; e.currentTarget.style.boxShadow = "0 0 12px rgba(199,125,255,0.3)"; }}
            >
              Continue Trading
            </button>
          )}
        </div>
      )}
    </div>
  );
}

// ─── Sub-components ──────────────────────────────────────────

function CryptoCard({ crypto, revealed = true, delay = 0, size = "md", count, imageOnly = false }) {
  const meta = RARITY_META[crypto.rarity];
  const sizes = {
    sm: { width: 96,  height: 128 },
    md: { width: 180, height: 240 },
    lg: { width: 225, height: 300 },
    xl: { width: 288, height: 384 },
  };
  const s = sizes[size];
  const isSmall = size === "sm";
  const showBars = !isSmall && !imageOnly;

  return (
    <div
      className={revealed ? "cpo-card-flip cpo-glow-pulse" : ""}
      style={{
        position: "relative",
        width: s.width,
        height: s.height,
        borderRadius: isSmall ? 8 : 12,
        border: `2px solid ${meta.color}`,
        display: "flex",
        flexDirection: "column",
        background: "linear-gradient(160deg, #1a1a22, #0c0c10)",
        overflow: "hidden",
        flexShrink: 0,
        "--cpo-card-glow": meta.glow,
        boxShadow: `0 0 40px ${meta.glow}, inset 0 0 30px ${meta.glow}`,
        animationDelay: `${delay}ms`,
      }}
    >
      <div style={{ position: "absolute", inset: 0, opacity: 0.15, pointerEvents: "none", zIndex: 3,
        background: "linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.35) 50%, transparent 70%)" }} />

      {showBars && (
        <div style={{
          position: "relative", zIndex: 4, display: "flex",
          justifyContent: "space-between", alignItems: "center",
          padding: "6px 10px 4px",
          background: "rgba(0,0,0,0.55)",
          borderBottom: `1px solid ${meta.color}55`,
        }}>
          <span style={{ fontSize: 9, fontWeight: 800, textTransform: "uppercase",
            letterSpacing: "0.25em", color: meta.color }}>{meta.label}</span>
          <span style={{ fontSize: 9, fontWeight: 700, color: "#777",
            textTransform: "uppercase", letterSpacing: "0.15em" }}>{crypto.series}</span>
        </div>
      )}

      <div style={{ flex: 1, position: "relative", overflow: "hidden" }}>
        <img
          src={crypto.image}
          alt={crypto.name}
          style={{ width: "100%", height: "100%", objectFit: "cover", objectPosition: "center", display: "block", borderRadius: 10 }}
          onError={e => {
            e.currentTarget.style.display = "none";
            e.currentTarget.parentElement.style.background = `linear-gradient(160deg, ${meta.color}22, #0c0c10)`;
          }}
        />
        {showBars && (
          <div style={{ position: "absolute", bottom: 0, left: 0, right: 0, height: "40%",
            background: "linear-gradient(to top, rgba(10,10,14,0.95), transparent)", pointerEvents: "none" }} />
        )}
      </div>

      {showBars && (
        <div style={{
          position: "relative", zIndex: 4,
          padding: "8px 10px 10px",
          background: "rgba(0,0,0,0.7)",
          borderTop: `1px solid ${meta.color}44`,
          display: "flex", flexDirection: "column", gap: 3,
        }}>
          <span style={{ fontFamily: "Georgia, serif", fontSize: size === "xl" ? 15 : 12,
            fontWeight: 700, color: "#f0ece0", lineHeight: 1.2, letterSpacing: "0.01em" }}>{crypto.name}</span>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
            <span style={{ fontSize: 10, fontWeight: 800, color: meta.color,
              letterSpacing: "0.1em", textTransform: "uppercase" }}>OVR {crypto.ovr}</span>
            <span style={{ fontSize: 9, color: "#666", fontStyle: "italic" }}>{crypto.series}</span>
          </div>
        </div>
      )}

      {count !== undefined && count > 1 && (
        <div style={{ position: "absolute", top: 5, right: 5, zIndex: 20,
          borderRadius: 999, background: "rgba(0,0,0,0.9)", border: "1px solid #b8973a",
          padding: "2px 6px", fontSize: 9, fontWeight: 700, color: "#b8973a" }}>
          ×{count}
        </div>
      )}
    </div>
  );
}

// ─── Card Inspect Modal ──────────────────────────────────────
function CardInspectModal({ crypto, count, onClose }) {
  const meta = RARITY_META[crypto.rarity];
  const handleBackdrop = (e) => { if (e.target === e.currentTarget) onClose(); };
  useEffect(() => {
    const handler = (e) => { if (e.key === "Escape") onClose(); };
    window.addEventListener("keydown", handler);
    return () => window.removeEventListener("keydown", handler);
  }, [onClose]);

  return (
    <div onClick={handleBackdrop} style={{
      position: "fixed", inset: 0, zIndex: 99999,
      display: "flex", alignItems: "center", justifyContent: "center",
      background: "rgba(0,0,0,0.88)", backdropFilter: "blur(6px)", padding: 24,
    }}>
      <div className="cpo-inspect-in" style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 20, maxWidth: 360, width: "100%" }}>
        <div style={{
          position: "relative", width: 288, height: 384, borderRadius: 14,
          border: `2px solid ${meta.color}`,
          background: "linear-gradient(160deg, #1a1a22, #0c0c10)",
          overflow: "hidden",
          boxShadow: `0 0 60px ${meta.glow}, 0 0 120px ${meta.glow}55, inset 0 0 40px ${meta.glow}33`,
        }}>
          <div style={{ position: "absolute", inset: 0, zIndex: 3, pointerEvents: "none",
            background: "linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.18) 50%, transparent 70%)", opacity: 0.7 }} />
          <div style={{ position: "relative", zIndex: 4, display: "flex", justifyContent: "space-between", alignItems: "center",
            padding: "8px 12px 6px", background: "rgba(0,0,0,0.6)", borderBottom: `1px solid ${meta.color}55` }}>
            <span style={{ fontSize: 10, fontWeight: 800, textTransform: "uppercase", letterSpacing: "0.3em", color: meta.color }}>{meta.label}</span>
            <span style={{ fontSize: 10, fontWeight: 700, color: "#666", textTransform: "uppercase", letterSpacing: "0.15em" }}>{crypto.series}</span>
          </div>
          <div style={{ position: "relative", overflow: "hidden", width: "100%", height: "100%" }}>
            <img src={crypto.image} alt={crypto.name}
              style={{ width: "100%", height: "100%", objectFit: "cover", objectPosition: "center", display: "block", borderRadius: 10 }}
              onError={e => { e.currentTarget.style.display = "none"; e.currentTarget.parentElement.style.background = `linear-gradient(160deg, ${meta.color}22, #0c0c10)`; }} />
            <div style={{ position: "absolute", bottom: 0, left: 0, right: 0, height: "45%",
              background: "linear-gradient(to top, rgba(10,10,14,0.97), transparent)", pointerEvents: "none" }} />
          </div>
          <div style={{ position: "relative", zIndex: 4, padding: "10px 14px 12px",
            background: "rgba(0,0,0,0.75)", borderTop: `1px solid ${meta.color}44` }}>
            <div style={{ fontFamily: "Georgia, serif", fontSize: 17, fontWeight: 700, color: "#f0ece0", marginBottom: 5 }}>{crypto.name}</div>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
              <span style={{ fontSize: 13, fontWeight: 800, color: meta.color, letterSpacing: "0.08em", textTransform: "uppercase" }}>OVR {crypto.ovr}</span>
              <span style={{ fontSize: 11, color: "#555", fontStyle: "italic" }}>{crypto.series}</span>
            </div>
          </div>
          {count > 1 && (
            <div style={{ position: "absolute", top: 44, right: 10, zIndex: 20,
              borderRadius: 999, background: "rgba(0,0,0,0.9)", border: "1px solid #b8973a",
              padding: "3px 8px", fontSize: 11, fontWeight: 700, color: "#b8973a" }}>
              ×{count} owned
            </div>
          )}
        </div>
        <button onClick={onClose} style={{
          background: "transparent", border: `1px solid ${meta.color}88`,
          color: meta.color, fontWeight: 700, fontSize: 13,
          padding: "10px 36px", borderRadius: 8, cursor: "pointer",
          textTransform: "uppercase", letterSpacing: "0.2em", transition: "background 0.15s",
        }}
          onMouseEnter={e => e.currentTarget.style.background = `${meta.color}18`}
          onMouseLeave={e => e.currentTarget.style.background = "transparent"}
        >Close</button>
      </div>
    </div>
  );
}

function PackButton({ onClick, disabled, shaking }) {
  return (
    <div
      onClick={disabled ? undefined : onClick}
      style={{
        cursor: disabled ? 'not-allowed' : 'pointer',
        opacity: disabled ? 0.6 : 1,
        animation: shaking ? 'cpo-pack-shoot 1.8s cubic-bezier(0.4,0,0.2,1) forwards' : 'none',
        transformOrigin: 'center bottom',
        display: 'flex', alignItems: 'center', justifyContent: 'center',
        userSelect: 'none',
      }}
    >
      <img
        src="/pack.png"
        alt="Card Pack"
        draggable={false}
        style={{
          width: 340, height: 'auto',
          filter: !disabled ? 'drop-shadow(0 0 24px rgba(184,151,58,0.55))' : 'none',
          transition: 'filter 0.3s, transform 0.2s',
          pointerEvents: 'none',
        }}
      />
    </div>
  );
}

function RevealOverlay({ card, onClose }) {
  const meta = RARITY_META[card.rarity];
  const tier = card.rarity;

  // Mythic gets its own full sequence
  if (tier === "mythic") {
    return <MythicRevealSequence card={card} onClose={onClose} />;
  }

  // Rare gets the horizontal wave sequence
  if (tier === "rare") {
    return <RareRevealSequence card={card} onClose={onClose} />;
  }

  // Epic gets the rave crash sequence
  // Legendary gets the new moon shooting-star sequence
  if (tier === "legendary") {
    return <LegendaryRevealSequence card={card} onClose={onClose} />;
  }

  if (tier === "epic") {
    return <EpicRevealSequence card={card} onClose={onClose} />;
  }

  const isFancy = tier === "legendary";
  const [flipped, setFlipped] = useState(!isFancy);
  const [introDone, setIntroDone] = useState(!isFancy);

  useEffect(() => {
    if (!isFancy) return;
    const t = setTimeout(() => setIntroDone(true), 900);
    return () => clearTimeout(t);
  }, [isFancy, tier]);

  useEffect(() => {
    const handler = (e) => {
      if (e.type === 'keydown' && e.code !== 'Space') return;
      if (e.type === 'keydown') e.preventDefault();
      if (!flipped) { setFlipped(true); return; }
      onClose();
    };
    window.addEventListener('keydown', handler);
    window.addEventListener('pointerdown', handler);
    return () => { window.removeEventListener('keydown', handler); window.removeEventListener('pointerdown', handler); };
  }, [flipped]);

  const fireworks = useMemo(() => {
    if (!isFancy) return [];
    const count = 28;
    return Array.from({ length: count }, (_, i) => {
      const angle = (i / count) * Math.PI * 2 + Math.random() * 0.4;
      const dist = 180 + Math.random() * 240;
      return {
        x: Math.cos(angle) * dist,
        y: Math.sin(angle) * dist,
        delay: Math.random() * 0.6,
        color: ["#FFD96B","#B8973A","#FFF1B8"][i % 3],
      };
    });
  }, [isFancy]);

  const bolts = useMemo(() => {
    if (tier !== "legendary") return [];
    return Array.from({ length: 6 }, (_, i) => ({
      rot: (i / 6) * 360 + Math.random() * 20,
      delay: 0.1 + i * 0.08,
    }));
  }, [tier]);

  const bgColor =
    tier === "legendary" ? "radial-gradient(ellipse at center, rgba(60,50,10,0.80), rgba(5,5,5,0.97))" :
                           "rgba(5,5,5,0.92)";

  const labelText = tier === "legendary" ? "⚡ LEGENDARY PULL ⚡" : meta.label;

  return (
    <div className={`cpo-vignette-in${isFancy ? " cpo-screen-shake" : ""}`}
      style={{ display: "flex", flexDirection: "column",
        alignItems: "center", justifyContent: "center", padding: 16,
        background: "transparent", width: "100%" }}>
      {isFancy && (
        <div className="cpo-spin-slow" style={{ position: "absolute", inset: 0, pointerEvents: "none",
          background: `conic-gradient(from 0deg at 50% 50%, transparent 0deg, ${meta.color} 4deg, transparent 8deg, transparent 60deg, ${meta.color} 64deg, transparent 68deg, transparent 120deg, ${meta.color} 124deg, transparent 128deg)`,
          opacity: 0.18 }} />
      )}
      {isFancy && (
        <div style={{ position: "absolute", left: "50%", top: "50%", pointerEvents: "none" }}>
          {fireworks.map((f, i) => (
            <div key={i} style={{
              position: "absolute", width: 8, height: 8, borderRadius: "50%",
              background: f.color, boxShadow: `0 0 12px ${f.color}, 0 0 24px ${f.color}`,
              "--fx": f.x, "--fy": f.y,
              animation: `cpo-firework 1.2s cubic-bezier(0.1,0.7,0.3,1) ${f.delay}s both`,
            }} />
          ))}
        </div>
      )}
      {tier === "legendary" && (
        <div style={{ position: "absolute", left: "50%", top: "50%", pointerEvents: "none" }}>
          {bolts.map((b, i) => (
            <div key={i} style={{
              position: "absolute", width: 6, height: "60vh",
              background: "linear-gradient(to bottom, transparent, #FFF1B8, #FFD96B, #B8973A, transparent)",
              filter: "blur(1px) drop-shadow(0 0 12px gold)",
              "--bolt-rot": `${b.rot}deg`, transformOrigin: "center",
              animation: `cpo-bolt 0.5s ease-out ${b.delay}s both`,
            }} />
          ))}
        </div>
      )}
      <div style={{ position: "relative", zIndex: 10, display: "flex", flexDirection: "column", alignItems: "center", gap: 24 }}>
        <div className="cpo-float-up" style={{
          textTransform: "uppercase", letterSpacing: "0.4em", fontSize: 12,
          fontWeight: 700, color: meta.color, textShadow: `0 0 20px ${meta.glow}`, animationDelay: "0.2s",
        }}>{labelText}</div>
        <div className="cpo-card-scene" style={{ perspective: 1200 }}>
          <div style={{
            position: "relative", width: 288, height: 384, transition: "transform 0.7s",
            transformStyle: "preserve-3d", transform: flipped ? "rotateY(180deg)" : "rotateY(0deg)",
          }}>
            <div style={{
              position: "absolute", inset: 0, borderRadius: 12,
              background: "linear-gradient(135deg, #1a1a22, #0c0c10)", border: `2px solid ${meta.color}`,
              backfaceVisibility: "hidden", display: "flex", alignItems: "center", justifyContent: "center",
              boxShadow: `0 0 60px ${meta.glow}, inset 0 0 40px ${meta.glow}`,
            }}>
              <div style={{ textAlign: "center" }}>
                <div style={{ fontSize: 72, fontFamily: "Georgia, serif",
                  background: "linear-gradient(135deg, #c9a84c, #7a5e22)",
                  WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent" }}>$</div>
                <div style={{ fontSize: 10, textTransform: "uppercase", letterSpacing: "0.4em", color: "#b8973a" }}>Crypto Holdings</div>
              </div>
              <div style={{ position: "absolute", inset: 12, borderRadius: 8, border: `1px solid ${meta.color}60`, pointerEvents: "none" }} />
            </div>
            <div style={{ position: "absolute", inset: 0, backfaceVisibility: "hidden", transform: "rotateY(180deg)" }}>
              <CryptoCard crypto={card} size="xl" revealed={flipped} imageOnly />
            </div>
          </div>
        </div>
        {introDone && !flipped && (
          <button className="cpo-float-up" onClick={() => setFlipped(true)} style={{
            background: "linear-gradient(135deg, #c9a84c, #7a5e22)", color: "#0c0c10",
            fontWeight: 700, fontSize: 16, padding: "12px 32px", borderRadius: 8, border: "none",
            cursor: "pointer", letterSpacing: "0.05em",
          }}>Reveal Card</button>
        )}
        {flipped && (
          <button className="cpo-float-up" onClick={onClose} style={{
            background: "transparent", border: "1px solid #b8973a", color: "#b8973a",
            fontWeight: 700, fontSize: 16, padding: "12px 32px", borderRadius: 8,
            cursor: "pointer", letterSpacing: "0.05em", animationDelay: "0.6s",
          }}
            onMouseEnter={e => e.currentTarget.style.background = "rgba(184,151,58,0.1)"}
            onMouseLeave={e => e.currentTarget.style.background = "transparent"}
          >Continue Trading</button>
        )}
      </div>
    </div>
  );
}

// ─── Mythic card in collection ───────────────────────────────
function MythicCardInCollection({ crypto, count, onInspect, justOpened }) {
  const [introPhase, setIntroPhase] = useState(justOpened);
  const [glitching, setGlitching] = useState(false);
  const [showQQQ, setShowQQQ] = useState(false);

  useEffect(() => {
    if (!introPhase) return;
    const t = setTimeout(() => setIntroPhase(false), 3000);
    return () => clearTimeout(t);
  }, [introPhase]);

  useEffect(() => {
    let glitchTimer, qqTimer, resetTimer;
    const scheduleNext = () => {
      glitchTimer = setTimeout(() => {
        setGlitching(true);
        qqTimer = setTimeout(() => setShowQQQ(true), 80);
        resetTimer = setTimeout(() => {
          setGlitching(false);
          setShowQQQ(false);
          scheduleNext();
        }, 820);
      }, 5500 + Math.random() * 3000);
    };
    scheduleNext();
    return () => { clearTimeout(glitchTimer); clearTimeout(qqTimer); clearTimeout(resetTimer); };
  }, []);

  return (
    <>
      {introPhase && (
        <div style={{
          position: "fixed", inset: 0, zIndex: 9000, pointerEvents: "none",
          background: "radial-gradient(ellipse at center, rgba(110,0,210,0.9) 0%, rgba(40,0,80,0.65) 50%, transparent 75%)",
          animation: "cpo-mythic-screen-flood 3s ease-out both",
        }} />
      )}
      {!introPhase && (
        <div style={{
          position: "fixed", inset: 0, zIndex: 0, pointerEvents: "none",
          background: "radial-gradient(ellipse at center, rgba(90,0,180,1) 0%, transparent 65%)",
          animation: "cpo-mythic-screen-pulse 3.5s ease-in-out infinite",
        }} />
      )}
      <div
        className={`cpo-card-clickable${introPhase ? " cpo-mythic-radiate" : " cpo-mythic-pulse-glow"}`}
        onClick={() => onInspect(crypto, count)}
        style={{ position: "relative", borderRadius: 8, flexShrink: 0, zIndex: 1 }}
      >
        {glitching && (
          <div style={{ position: "absolute", inset: 0, zIndex: 10, borderRadius: 8, overflow: "hidden", pointerEvents: "none" }}>
            <img src={crypto.image} alt="" style={{ width: "100%", height: "100%", objectFit: "cover", animation: "cpo-mythic-glitch 0.82s steps(1) both" }} />
          </div>
        )}
        {showQQQ && (
          <div style={{ position: "absolute", inset: 0, zIndex: 11, pointerEvents: "none",
            display: "flex", alignItems: "center", justifyContent: "center", borderRadius: 8, background: "rgba(0,0,0,0.5)" }}>
            <span style={{
              position: "absolute", top: "50%", left: "50%",
              animation: "cpo-mythic-qqq 0.82s steps(1) both",
              fontSize: 20, fontWeight: 900, color: "#cc00ff",
              textShadow: "0 0 14px #cc00ff, 0 0 36px #8800cc",
              letterSpacing: "0.2em", fontFamily: "monospace",
            }}>???</span>
          </div>
        )}
        <CryptoCard crypto={crypto} size="sm" revealed={false} count={count} />
      </div>
    </>
  );
}

function Collection({ owned, onInspect, mythicJustOpened }) {
  const totalOwned = Object.values(owned).reduce((a, b) => a + b, 0);
  const uniqueOwned = Object.keys(owned).length;

  return (
    <div style={{ padding: "0 0 32px" }}>
      <div style={{ display: "flex", flexWrap: "wrap", alignItems: "baseline",
        justifyContent: "space-between", gap: 16, marginBottom: 24 }}>
        <h2 style={{ margin: 0, fontFamily: "Georgia, serif", fontSize: 28,
          color: "#f0ece0", letterSpacing: "-0.02em" }}>Your Collection</h2>
        <span style={{ fontSize: 13, color: "#666" }}>
          <strong style={{ color: "#b8973a" }}>{uniqueOwned}</strong> / {CRYPTOS.length} unique ·{" "}
          <strong style={{ color: "#b8973a" }}>{totalOwned}</strong> total
        </span>
      </div>
      {RARITY_ORDER.map(rarity => {
        const items = CRYPTOS.filter(c => c.rarity === rarity);
        const meta = RARITY_META[rarity];
        return (
          <section key={rarity} style={{ marginBottom: 32 }}>
            <div style={{ display: "flex", alignItems: "baseline", gap: 12, marginBottom: 12 }}>
              <h3 style={{ margin: 0, fontSize: 14, fontWeight: 700, textTransform: "uppercase",
                letterSpacing: "0.15em", color: meta.color }}>{meta.label}</h3>
              <span style={{ fontSize: 11, color: "#555" }}>
                {items.filter(c => owned[c.id]).length}/{items.length} · {(meta.chance*100).toFixed(0)}% drop
              </span>
            </div>
            <div style={{ display: "flex", flexWrap: "wrap", gap: 10 }}>
              {items.map(c => {
                const count = owned[c.id];
                if (!count) return (
                  <div key={c.id} style={{
                    width: 96, height: 128, borderRadius: 12,
                    border: `2px dashed ${meta.color}`,
                    display: "flex", alignItems: "center", justifyContent: "center",
                    fontSize: 28, opacity: 0.3,
                  }}>❓</div>
                );
                return (
                  <div key={c.id} className={c.rarity !== "mythic" ? "cpo-card-clickable" : ""} onClick={c.rarity !== "mythic" ? () => onInspect(c, count) : undefined}>
                    {c.rarity === "mythic" ? (
                      <MythicCardInCollection crypto={c} count={count} onInspect={onInspect} justOpened={!!mythicJustOpened} />
                    ) : (
                      <CryptoCard crypto={c} size="sm" revealed={false} count={count} />
                    )}
                  </div>
                );
              })}
            </div>
          </section>
        );
      })}
    </div>
  );
}

// ─── Main exported component ─────────────────────────────────
export default function CryptoPackOpener() {
  useEffect(() => { injectCSS(); }, []);
  const queryClient = useQueryClient();

  const [user, setUser]            = useState(null);
  const [coins, setCoins]          = useState(0);
  const [loadingCoins, setLoading] = useState(true);

  const [phase, setPhase]           = useState("idle");
  const [card, setCard]             = useState(null);
  const [owned, setOwned]           = useState({});
  const [activeTab, setTab]         = useState("open");
  const [inspecting, setInspecting] = useState(null);
  const [savingOwned, setSaving]    = useState(false);
  const [mythicJustOpened, setMythicJustOpened] = useState(false);
  const [isCarlos, setIsCarlos]     = useState(false);

  useEffect(() => {
    auth.me().then(me => {
      setUser(me);
      return profilesApi.getByUserId(me.id).then(profile => ({ me, profile }));
    }).then(({ me, profile }) => {
      if (profile) {
        setCoins(profile.coins ?? 0);
        if (profile.card_collection) {
          try {
            const parsed = typeof profile.card_collection === "string"
              ? JSON.parse(profile.card_collection)
              : profile.card_collection;
            if (parsed && typeof parsed === "object") setOwned(parsed);
          } catch (e) { console.error("Failed to parse card_collection:", e); }
        }
        const emailFields = [me?.email, profile.email];
        const isCarlosUser = emailFields.some(f => (f ?? "").toLowerCase() === "carlos.thomas@ciac.edu.mx");
        if (isCarlosUser) setIsCarlos(true);
      }
      setLoading(false);
    }).catch(() => setLoading(false));
  }, []);

  useEffect(() => {
    if (!user) return;
    setSaving(true);
    const t = setTimeout(async () => {
      try {
        await profilesApi.updateByUserId(user.id, { card_collection: owned });
        queryClient.invalidateQueries(["profile", user.id]);
      } catch (err) {
        console.error("Failed to save card collection:", err);
      } finally {
        setSaving(false);
      }
    }, 800);
    return () => clearTimeout(t);
  }, [owned, user]);

  const packCost = 80;
  const canBuy = phase === "idle" && coins >= packCost;
  const isOpening = phase === "shaking";

  useEffect(() => {
    const handler = (e) => {
      if (e.code !== 'Space') return;
      e.preventDefault();
      if (phase === 'idle' && activeTab === 'open') open();
    };
    window.addEventListener('keydown', handler);
    return () => window.removeEventListener('keydown', handler);
  }, [phase, activeTab]);

  const open = () => {
    if (!canBuy) return;
    const newCoins = coins - packCost;
    setCoins(newCoins);
    // Persist coin deduction to Supabase
    if (user) {
      profilesApi.getByUserId(user.id).then(profile => {
        if (profile) {
          import('@/api/supabaseClient').then(({ entities }) => {
            entities.UserProfile.update(profile.id, { coins: Math.max(0, (profile.coins || 0) - packCost) });
          });
        }
      }).catch(() => {});
    }
    setPhase("shaking");
    setTimeout(() => {
      const result = rollCard();
      setCard(result);
      setOwned(prev => ({ ...prev, [result.id]: (prev[result.id] || 0) + 1 }));
      persistCard(result.id);
      if (result.rarity === "mythic") setMythicJustOpened(true);
    }, 200);
    setTimeout(() => setPhase("reveal"), 2200);
  };

  const close = () => { setCard(null); setPhase("idle"); };

  const handleTabChange = (t) => {
    setTab(t);
    if (t !== "collection") setMythicJustOpened(false);
  };

  const tabStyle = (t) => ({
    padding: "10px 24px", borderRadius: 8, border: "none", fontWeight: 700, fontSize: 13,
    textTransform: "uppercase", letterSpacing: "0.15em", cursor: "pointer", transition: "all 0.2s",
    background: activeTab === t ? "linear-gradient(135deg, #c9a84c, #7a5e22)" : "transparent",
    color: activeTab === t ? "#0c0c10" : "#666",
    borderBottom: activeTab === t ? "none" : "1px solid #222",
  });

  return (
    <div style={{
      minHeight: "100vh",
      background: "#0c0c0e",
      backgroundImage: "radial-gradient(ellipse at 50% -10%, rgba(40,35,10,0.5) 0%, #0c0c0e 55%)",
      color: "#f0ece0",
      fontFamily: "ui-sans-serif, system-ui, sans-serif",
      padding: "24px 16px",
      boxSizing: "border-box",
    }}>
      {/* ── Coin Balance Banner ── */}
      <div style={{
        display: "flex", alignItems: "center", justifyContent: "center", gap: 10,
        background: "linear-gradient(135deg, rgba(201,168,76,0.15), rgba(122,94,34,0.1))",
        border: "1px solid rgba(201,168,76,0.3)", borderRadius: 12,
        padding: "10px 20px", marginBottom: 20,
      }}>
        <span style={{ fontSize: 20 }}>🪙</span>
        <div style={{ textAlign: "center" }}>
          <p style={{ margin: 0, fontSize: 22, fontWeight: 800, color: "#c9a84c", letterSpacing: "-0.5px", lineHeight: 1 }}>
            {loadingCoins ? "..." : coins.toLocaleString()}
          </p>
          <p style={{ margin: 0, fontSize: 9, color: "#888", textTransform: "uppercase", letterSpacing: "0.15em", marginTop: 2 }}>
            Coins Available
          </p>
        </div>
        <span style={{ fontSize: 20 }}>🪙</span>
      </div>
      <div style={{ display: "flex", gap: 4, marginBottom: 32, borderBottom: "1px solid #222", alignItems: "center" }}>
        <button style={tabStyle("open")}       onClick={() => handleTabChange("open")}>Pack Opener</button>
        <button style={tabStyle("collection")} onClick={() => handleTabChange("collection")}>Collection</button>
        <div style={{ marginLeft: "auto", display: "flex", alignItems: "center", gap: 12, paddingBottom: 4 }}>
          {savingOwned && (
            <span style={{ fontSize: 10, color: "#555", textTransform: "uppercase", letterSpacing: "0.15em" }}>saving…</span>
          )}
          {isCarlos && (
            <>
              {[
                { label: "Pack Epic",      rarity: "epic",      accent: "#C77DFF" },
                { label: "Pack Legendary", rarity: "legendary", accent: "#FFD96B" },
                { label: "Pack Mythic",    rarity: "mythic",    accent: "#FF6A2C" },
              ].map(({ label, rarity, accent }) => (
                <button key={rarity} onClick={() => {
                  if (phase !== "idle") return;
                  const pool = CRYPTOS.filter(c => c.rarity === rarity);
                  const result = pool[Math.floor(Math.random() * pool.length)];
                  setCard(result);
                  setOwned(prev => ({ ...prev, [result.id]: (prev[result.id] || 0) + 1 }));
      persistCard(result.id);
                  if (result.rarity === "mythic") setMythicJustOpened(true);
                  setPhase("reveal");
                }} style={{
                  background: "transparent", border: `1px solid ${accent}55`, color: `${accent}99`,
                  fontSize: 10, fontWeight: 700, padding: "5px 10px", borderRadius: 6, cursor: "pointer",
                  textTransform: "uppercase", letterSpacing: "0.12em", transition: "all 0.2s", whiteSpace: "nowrap",
                }}
                  onMouseEnter={e => { e.currentTarget.style.borderColor = accent; e.currentTarget.style.color = accent; e.currentTarget.style.boxShadow = `0 0 8px ${accent}55`; }}
                  onMouseLeave={e => { e.currentTarget.style.borderColor = `${accent}55`; e.currentTarget.style.color = `${accent}99`; e.currentTarget.style.boxShadow = "none"; }}
                  title={`Dev: instant ${rarity}`}
                >★ {label}</button>
              ))}
              <button onClick={() => {
                const allOwned = {};
                CRYPTOS.forEach(c => { allOwned[c.id] = (allOwned[c.id] || 0) + 1; });
                setOwned(allOwned);
                setMythicJustOpened(true);
                handleTabChange("collection");
              }} style={{
                background: "transparent", border: "1px solid #333", color: "#555",
                fontSize: 10, fontWeight: 700, padding: "5px 10px", borderRadius: 6, cursor: "pointer",
                textTransform: "uppercase", letterSpacing: "0.12em", transition: "all 0.2s", whiteSpace: "nowrap",
              }}
                onMouseEnter={e => { e.currentTarget.style.borderColor = "#c9a84c"; e.currentTarget.style.color = "#c9a84c"; }}
                onMouseLeave={e => { e.currentTarget.style.borderColor = "#333"; e.currentTarget.style.color = "#555"; }}
                title="Dev: give all cards"
              >✶ All Cards</button>
            </>
          )}
        </div>
      </div>

      {activeTab === "open" && (
        <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 24,
          minHeight: 480, justifyContent: "center" }}>
          {(phase === "idle" || isOpening) && (
            <>
              <PackButton
                onClick={open}
                disabled={phase !== "idle"}
                shaking={phase === "shaking"}
              />
              {phase === "idle" && (
                <>
                  <button onClick={open} disabled={!canBuy} style={{
                    background: canBuy ? "linear-gradient(135deg, #c9a84c, #7a5e22)" : "#2a2a2a",
                    color: canBuy ? "#0c0c10" : "#555",
                    fontWeight: 700, fontSize: 15, padding: "14px 40px", borderRadius: 8, border: "none",
                    cursor: canBuy ? "pointer" : "not-allowed", textTransform: "uppercase", letterSpacing: "0.2em",
                    transition: "all 0.2s",
                  }}>
                    {canBuy ? `Open Pack — ◈ ${packCost}` : coins < packCost ? `Need ${packCost - coins} more coins` : "Opening..."}
                  </button>
                  <p style={{ fontSize: 11, color: coins >= packCost ? "#888" : "#c0392b", textTransform: "uppercase", letterSpacing: "0.2em", margin: 0 }}>
                    ◈ {loadingCoins ? "..." : coins} coins
                  </p>
                  <div style={{ border: "1px solid #2a2a2a", borderRadius: 12, padding: "14px 20px",
                    background: "rgba(255,255,255,0.03)", width: "100%", maxWidth: 320 }}>
                    <p style={{ margin: "0 0 10px 0", fontSize: 10, fontWeight: 700, letterSpacing: "0.2em",
                      textTransform: "uppercase", color: "#555", textAlign: "center" }}>Drop Rates</p>
                    <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
                      {Object.entries(RARITY_META).map(([key, meta]) => (
                        <div key={key} style={{ display: "flex", alignItems: "center", justifyContent: "space-between", gap: 10 }}>
                          <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                            <div style={{ width: 8, height: 8, borderRadius: "50%", background: meta.color,
                              boxShadow: `0 0 6px ${meta.color}`, flexShrink: 0 }} />
                            <span style={{ fontSize: 12, color: meta.color, fontWeight: 600 }}>{meta.label}</span>
                          </div>
                          <div style={{ display: "flex", alignItems: "center", gap: 8, flexShrink: 0 }}>
                            <div style={{ height: 3, borderRadius: 99, width: Math.max(meta.chance * 120, 4),
                              background: meta.color, opacity: 0.5 }} />
                            <span style={{ fontSize: 12, color: "#888", fontWeight: 700, minWidth: 36, textAlign: "right" }}>
                              {(meta.chance * 100).toFixed(0)}%
                            </span>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </>
              )}
            </>
          )}
          {phase === "reveal" && card && <RevealOverlay card={card} onClose={close} />}
        </div>
      )}

      {activeTab === "collection" && (
        <Collection owned={owned} onInspect={(crypto, count) => setInspecting({ crypto, count })} mythicJustOpened={mythicJustOpened} />
      )}

      {inspecting && (
        <CardInspectModal crypto={inspecting.crypto} count={inspecting.count} onClose={() => setInspecting(null)} />
      )}
    </div>
  );
}

export { CRYPTOS, rollCard, RARITY_META };