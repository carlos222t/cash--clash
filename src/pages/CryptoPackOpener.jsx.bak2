  /* ── NEW EPIC ANIMATIONS ── */

  /* Card crashes from top with bounce */
  @keyframes cpo-epic-crash {
    0%   { transform: translateY(-130vh) rotate(6deg) scale(1.25); opacity: 0; }
    50%  { transform: translateY(18px) rotate(-2deg) scale(1.04); opacity: 1; }
