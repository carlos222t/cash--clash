// ============================================================
//  CryptoPackOpener.jsx
//  Drop-in component for Cash Clash
//  Props: coins (number), packCost (number), onSpend (fn), onResult (fn)
// ============================================================

import { useState, useEffect, useMemo } from "react";

// ─── Data ────────────────────────────────────────────────────
const RARITY_ORDER = ["common", "rare", "epic", "legendary", "mythic"];

const RARITY_META = {
  common:    { label: "Common",    color: "#9BA8C0", glow: "rgba(155,168,192,0.35)", chance: 0.50 },
  rare:      { label: "Rare",      color: "#4A9EE8", glow: "rgba(74,158,232,0.60)",  chance: 0.35 },
  epic:      { label: "Epic",      color: "#C77DFF", glow: "rgba(199,125,255,0.75)", chance: 0.10 },
  legendary: { label: "Legendary", color: "#FFD96B", glow: "rgba(255,217,107,0.85)", chance: 0.04 },
  mythic:    { label: "Mythic",    color: "#FF6A2C", glow: "rgba(255,106,44,0.90)",  chance: 0.01 },
};

const CRYPTOS = [
  // Commons
  { id: "doge",  name: "Dogecoin",          symbol: "DOGE", rarity: "common",    emoji: "🐕", tagline: "Much wow, very coin" },
  { id: "shib",  name: "Shiba Inu",         symbol: "SHIB", rarity: "common",    emoji: "🐶", tagline: "The Doge killer" },
  { id: "xrp",   name: "Ripple",            symbol: "XRP",  rarity: "common",    emoji: "💧", tagline: "Liquid value" },
  { id: "ltc",   name: "Litecoin",          symbol: "LTC",  rarity: "common",    emoji: "🪙", tagline: "Silver to Bitcoin's gold" },
  { id: "trx",   name: "Tron",             symbol: "TRX",  rarity: "common",    emoji: "⚡", tagline: "Decentralize the web" },
  { id: "ada",   name: "Cardano",           symbol: "ADA",  rarity: "common",    emoji: "🔷", tagline: "Peer reviewed chain" },
  { id: "xlm",   name: "Stellar",           symbol: "XLM",  rarity: "common",    emoji: "✨", tagline: "Borderless payments" },
  { id: "algo",  name: "Algorand",          symbol: "ALGO", rarity: "common",    emoji: "🧮", tagline: "Pure proof of stake" },
  { id: "hbar",  name: "Hedera",            symbol: "HBAR", rarity: "common",    emoji: "🌐", tagline: "Hashgraph speed" },
  { id: "vet",   name: "VeChain",           symbol: "VET",  rarity: "common",    emoji: "📦", tagline: "Supply chain trust" },
  { id: "iota",  name: "IOTA",             symbol: "IOTA", rarity: "common",    emoji: "🕸️", tagline: "Tangle of things" },
  { id: "neo",   name: "NEO",              symbol: "NEO",  rarity: "common",    emoji: "🟢", tagline: "Smart economy" },
  // Rares
  { id: "bnb",   name: "BNB",              symbol: "BNB",  rarity: "rare",      emoji: "🟡", tagline: "Exchange titan" },
  { id: "matic", name: "Polygon",          symbol: "MATIC",rarity: "rare",      emoji: "🟣", tagline: "Layer 2 scaling" },
  { id: "atom",  name: "Cosmos",           symbol: "ATOM", rarity: "rare",      emoji: "🪐", tagline: "Internet of blockchains" },
  { id: "near",  name: "NEAR",            symbol: "NEAR", rarity: "rare",      emoji: "🌈", tagline: "Sharded scalability" },
  { id: "ftm",   name: "Fantom",           symbol: "FTM",  rarity: "rare",      emoji: "👻", tagline: "DAG consensus" },
  { id: "icp",   name: "Internet Computer",symbol: "ICP",  rarity: "rare",      emoji: "♾️", tagline: "Web3 cloud" },
  { id: "fil",   name: "Filecoin",         symbol: "FIL",  rarity: "rare",      emoji: "🗄️", tagline: "Decentralized storage" },
  { id: "aave",  name: "Aave",            symbol: "AAVE", rarity: "rare",      emoji: "👻", tagline: "Lending protocol" },
  { id: "uni",   name: "Uniswap",          symbol: "UNI",  rarity: "rare",      emoji: "🦄", tagline: "Swap anything" },
  // Epics
  { id: "sol",   name: "Solana",           symbol: "SOL",  rarity: "epic",      emoji: "☀️", tagline: "Lightning fast chain" },
  { id: "avax",  name: "Avalanche",        symbol: "AVAX", rarity: "epic",      emoji: "🏔️", tagline: "Subnet powerhouse" },
  { id: "dot",   name: "Polkadot",         symbol: "DOT",  rarity: "epic",      emoji: "🔴", tagline: "Parachain pioneer" },
  { id: "link",  name: "Chainlink",        symbol: "LINK", rarity: "epic",      emoji: "🔗", tagline: "Oracle of truth" },
  { id: "ton",   name: "Toncoin",          symbol: "TON",  rarity: "epic",      emoji: "💎", tagline: "Telegram native" },
  // Legendaries
  { id: "eth",   name: "Ethereum",         symbol: "ETH",  rarity: "legendary", emoji: "Ξ",  tagline: "World computer" },
  { id: "xmr",   name: "Monero",           symbol: "XMR",  rarity: "legendary", emoji: "🕶️", tagline: "True privacy coin" },
  { id: "wld",   name: "Worldcoin",        symbol: "WLD",  rarity: "legendary", emoji: "👁️", tagline: "Proof of human" },
  // Mythic
  { id: "btc",   name: "Bitcoin",          symbol: "BTC",  rarity: "mythic",    emoji: "₿",  tagline: "The original. Digital gold." },
];

function rollCard() {
  const r = Math.random();
  let rarity;
  if (r < 0.50)      rarity = "common";
  else if (r < 0.85) rarity = "rare";
  else if (r < 0.95) rarity = "epic";
  else if (r < 0.99) rarity = "legendary";
  else               rarity = "mythic";
  const pool = CRYPTOS.filter(c => c.rarity === rarity);
  return pool[Math.floor(Math.random() * pool.length)];
}

// ─── Inline CSS (injected once) ──────────────────────────────
const CSS = `
  @keyframes cpo-pack-shake {
    0%,100% { transform: rotate(0); }
    25% { transform: rotate(-3deg) translateY(-4px); }
    50% { transform: rotate(3deg) translateY(-8px); }
    75% { transform: rotate(-2deg) translateY(-3px); }
  }
  @keyframes cpo-pack-burst {
    0%   { transform: scale(1);   opacity: 1; }
    60%  { transform: scale(1.5); opacity: 0.7; }
    100% { transform: scale(2.6); opacity: 0; }
  }
  @keyframes cpo-card-flip {
    0%   { transform: rotateY(180deg) scale(0.6); opacity: 0; }
    60%  { opacity: 1; }
    100% { transform: rotateY(0) scale(1); opacity: 1; }
  }
  @keyframes cpo-glow-pulse {
    0%,100% { box-shadow: 0 0 30px var(--cpo-card-glow, transparent); }
    50%     { box-shadow: 0 0 70px var(--cpo-card-glow, transparent); }
  }
  @keyframes cpo-float-up {
    0%   { transform: translateY(20px); opacity: 0; }
    100% { transform: translateY(0);    opacity: 1; }
  }
  @keyframes cpo-vignette-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes cpo-spin-slow {
    to { transform: rotate(360deg); }
  }
  @keyframes cpo-firework {
    0%   { transform: translate(-50%,-50%) scale(0.4); opacity: 1; }
    100% { transform: translate(calc(-50% + var(--fx)*1px), calc(-50% + var(--fy)*1px)) scale(0.6); opacity: 0; }
  }
  @keyframes cpo-bolt {
    0%   { transform: translate(-50%,-50%) rotate(var(--bolt-rot,0deg)) scaleY(0); opacity: 0; }
    20%  { transform: translate(-50%,-50%) rotate(var(--bolt-rot,0deg)) scaleY(1); opacity: 1; }
    100% { transform: translate(-50%,-50%) rotate(var(--bolt-rot,0deg)) scaleY(1); opacity: 0; }
  }
  @keyframes cpo-mythic-descend {
    0%   { transform: translateY(-200%) scale(0.4); opacity: 0; filter: brightness(2); }
    60%  { transform: translateY(0) scale(1.05);   opacity: 1; filter: brightness(1.4); }
    100% { transform: translateY(0) scale(1);      opacity: 1; filter: brightness(1); }
  }
  @keyframes cpo-heaven-ray {
    0%   { opacity: 0; transform: translate(-50%,-100%) scaleY(0); }
    100% { opacity: 0.8; transform: translate(-50%,-50%) scaleY(1); }
  }
  @keyframes cpo-screen-shake {
    0%,100% { transform: translate(0,0); }
    20% { transform: translate(-4px,2px); }
    40% { transform: translate(4px,-2px); }
    60% { transform: translate(-2px,4px); }
    80% { transform: translate(2px,-4px); }
  }
  .cpo-pack-shake    { animation: cpo-pack-shake    0.55s ease-in-out infinite; }
  .cpo-pack-burst    { animation: cpo-pack-burst    0.7s ease-out forwards; }
  .cpo-card-flip     { animation: cpo-card-flip     0.7s cubic-bezier(0.2,0.9,0.3,1.2) both; }
  .cpo-glow-pulse    { animation: cpo-glow-pulse    2.4s ease-in-out infinite; }
  .cpo-float-up      { animation: cpo-float-up      0.5s ease-out both; }
  .cpo-vignette-in   { animation: cpo-vignette-in   0.4s ease-out both; }
  .cpo-screen-shake  { animation: cpo-screen-shake  0.4s ease-in-out; }
  .cpo-mythic-descend{ animation: cpo-mythic-descend 1.4s cubic-bezier(0.2,0.8,0.2,1) both; }
  .cpo-spin-slow     { animation: cpo-spin-slow 18s linear infinite; }
`;

let cssInjected = false;
function injectCSS() {
  if (cssInjected) return;
  const style = document.createElement("style");
  style.textContent = CSS;
  document.head.appendChild(style);
  cssInjected = true;
}

// ─── Sub-components ──────────────────────────────────────────

function CryptoCard({ crypto, revealed = true, delay = 0, size = "md", count }) {
  const meta = RARITY_META[crypto.rarity];
  const sizes = {
    sm: { width: 96,  height: 128, fontSize: 24 },
    md: { width: 176, height: 240, fontSize: 48 },
    lg: { width: 224, height: 320, fontSize: 72 },
    xl: { width: 288, height: 384, fontSize: 96 },
  };
  const s = sizes[size];

  return (
    <div
      className={revealed ? "cpo-card-flip cpo-glow-pulse" : ""}
      style={{
        position: "relative",
        width: s.width,
        height: s.height,
        borderRadius: 12,
        border: `2px solid ${meta.color}`,
        padding: 16,
        display: "flex",
        flexDirection: "column",
        alignItems: "center",
        justifyContent: "space-between",
        background: "linear-gradient(160deg, #1e1e26, #0f0f14)",
        overflow: "hidden",
        flexShrink: 0,
        "--cpo-card-glow": meta.glow,
        boxShadow: `0 0 40px ${meta.glow}, inset 0 0 30px ${meta.glow}`,
        animationDelay: `${delay}ms`,
      }}
    >
      {/* radial tint */}
      <div style={{ position: "absolute", inset: 0, opacity: 0.3, pointerEvents: "none",
        background: `radial-gradient(circle at 50% 0%, ${meta.color}, transparent 70%)` }} />
      {/* foil shimmer */}
      <div style={{ position: "absolute", inset: 0, opacity: 0.2, pointerEvents: "none",
        background: "linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.3) 50%, transparent 70%)" }} />

      {/* top row */}
      <div style={{ position: "relative", zIndex: 1, display: "flex", width: "100%",
        justifyContent: "space-between", fontSize: 10, fontWeight: 700,
        textTransform: "uppercase", letterSpacing: "0.2em" }}>
        <span style={{ color: meta.color }}>{meta.label}</span>
        <span style={{ color: "#888" }}>{crypto.symbol}</span>
      </div>

      {/* center */}
      <div style={{ position: "relative", zIndex: 1, display: "flex", flexDirection: "column",
        alignItems: "center", gap: 8 }}>
        <span style={{ fontSize: s.fontSize }}>{crypto.emoji}</span>
        <span style={{ fontFamily: "Georgia, serif", fontSize: 18, fontWeight: 700,
          color: "#f0ece0", textAlign: "center" }}>{crypto.name}</span>
      </div>

      {/* tagline */}
      <div style={{ position: "relative", zIndex: 1, textAlign: "center", fontSize: 10,
        fontStyle: "italic", color: "#777", padding: "0 4px", lineHeight: 1.4,
        fontFamily: "Georgia, serif" }}>"{crypto.tagline}"</div>

      {/* duplicate badge */}
      {count !== undefined && count > 1 && (
        <div style={{ position: "absolute", top: 6, right: 6, zIndex: 20,
          borderRadius: 999, background: "rgba(0,0,0,0.9)", border: "1px solid #b8973a",
          padding: "2px 6px", fontSize: 10, fontWeight: 700, color: "#b8973a" }}>
          ×{count}
        </div>
      )}
    </div>
  );
}

function PackButton({ onClick, disabled, shaking, bursting }) {
  return (
    <button
      onClick={onClick}
      disabled={disabled}
      className={shaking ? "cpo-pack-shake" : bursting ? "cpo-pack-burst" : ""}
      style={{
        position: "relative",
        width: 208,
        height: 288,
        borderRadius: 12,
        background: "linear-gradient(160deg, #1e1e26, #0f0f14)",
        border: "2px solid #b8973a",
        display: "flex",
        flexDirection: "column",
        alignItems: "center",
        justifyContent: "space-between",
        padding: "24px 24px",
        cursor: disabled ? "not-allowed" : "pointer",
        opacity: disabled ? 0.5 : 1,
        overflow: "hidden",
        transition: "transform 0.15s, box-shadow 0.15s",
        boxShadow: "0 20px 60px -15px rgba(0,0,0,0.7), 0 0 30px rgba(184,151,58,0.3)",
      }}
      onMouseEnter={e => { if (!disabled) { e.currentTarget.style.transform = "scale(1.05)"; e.currentTarget.style.boxShadow = "0 20px 60px -15px rgba(0,0,0,0.7), 0 0 40px rgba(184,151,58,0.45)"; } }}
      onMouseLeave={e => { e.currentTarget.style.transform = "scale(1)"; e.currentTarget.style.boxShadow = "0 20px 60px -15px rgba(0,0,0,0.7), 0 0 30px rgba(184,151,58,0.3)"; }}
    >
      {/* grid bg */}
      <div style={{ position: "absolute", inset: 0, opacity: 0.6, pointerEvents: "none",
        backgroundImage: "linear-gradient(rgba(184,151,58,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(184,151,58,0.04) 1px, transparent 1px)",
        backgroundSize: "40px 40px" }} />
      <div style={{ position: "absolute", inset: 8, borderRadius: 8,
        border: "1px solid rgba(184,151,58,0.3)", pointerEvents: "none" }} />
      <div style={{ position: "absolute", top: -4, left: "50%", transform: "translateX(-50%)",
        height: 4, width: 128, borderRadius: 999,
        background: "linear-gradient(135deg, #c9a84c, #7a5e22)" }} />

      <div style={{ position: "relative", zIndex: 1, textAlign: "center" }}>
        <div style={{ fontSize: 9, textTransform: "uppercase", letterSpacing: "0.4em", color: "#777" }}>Series I</div>
        <div style={{ fontSize: 12, fontFamily: "Georgia, serif", fontStyle: "italic",
          color: "#b8973a", marginTop: 4 }}>Bull Market Edition</div>
      </div>

      <div style={{ position: "relative", zIndex: 1 }}>
        <span style={{ fontSize: 72, fontFamily: "Georgia, serif",
          background: "linear-gradient(135deg, #c9a84c, #7a5e22)",
          WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent" }}>$</span>
      </div>

      <div style={{ position: "relative", zIndex: 1, textAlign: "center" }}>
        <div style={{ fontSize: 10, fontWeight: 900, textTransform: "uppercase",
          letterSpacing: "0.35em", background: "linear-gradient(135deg, #c9a84c, #7a5e22)",
          WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent" }}>
          Crypto Holdings
        </div>
        <div style={{ fontSize: 9, color: "#666", marginTop: 4, textTransform: "uppercase",
          letterSpacing: "0.2em" }}>1 Asset · Sealed</div>
      </div>
    </button>
  );
}

function RevealOverlay({ card, onClose }) {
  const meta = RARITY_META[card.rarity];
  const tier = card.rarity;
  const isFancy = tier === "epic" || tier === "legendary" || tier === "mythic";
  const [flipped, setFlipped] = useState(!isFancy);
  const [introDone, setIntroDone] = useState(!isFancy);

  useEffect(() => {
    if (!isFancy) return;
    const t = setTimeout(() => setIntroDone(true), tier === "mythic" ? 1600 : 900);
    return () => clearTimeout(t);
  }, [isFancy, tier]);

  const fireworks = useMemo(() => {
    if (!isFancy) return [];
    const count = tier === "mythic" ? 40 : tier === "legendary" ? 28 : 20;
    return Array.from({ length: count }, (_, i) => {
      const angle = (i / count) * Math.PI * 2 + Math.random() * 0.4;
      const dist = 180 + Math.random() * 240;
      return {
        x: Math.cos(angle) * dist,
        y: Math.sin(angle) * dist,
        delay: Math.random() * 0.6,
        color: tier === "mythic"
          ? ["#FF6A2C","#FFC857","#FFFFFF"][i % 3]
          : tier === "legendary"
            ? ["#FFD96B","#B8973A","#FFF1B8"][i % 3]
            : ["#C77DFF","#9D4EDD","#FFFFFF"][i % 3],
      };
    });
  }, [tier, isFancy]);

  const bolts = useMemo(() => {
    if (tier !== "legendary" && tier !== "mythic") return [];
    const n = tier === "mythic" ? 8 : 6;
    return Array.from({ length: n }, (_, i) => ({
      rot: (i / n) * 360 + Math.random() * 20,
      delay: 0.1 + i * 0.08,
    }));
  }, [tier]);

  const bgColor =
    tier === "mythic"    ? "radial-gradient(ellipse at center, rgba(80,30,10,0.85), rgba(5,5,5,0.98))" :
    tier === "legendary" ? "radial-gradient(ellipse at center, rgba(60,50,10,0.80), rgba(5,5,5,0.97))" :
    tier === "epic"      ? "radial-gradient(ellipse at center, rgba(40,10,70,0.75), rgba(5,5,5,0.97))" :
                           "rgba(5,5,5,0.92)";

  const labelText =
    tier === "mythic"    ? "✦ MYTHIC ASCENSION ✦" :
    tier === "legendary" ? "⚡ LEGENDARY PULL ⚡" :
    tier === "epic"      ? "✧ EPIC FIND ✧" : meta.label;

  return (
    <div
      className={`cpo-vignette-in${isFancy ? " cpo-screen-shake" : ""}`}
      style={{ position: "fixed", inset: 0, zIndex: 9999, display: "flex",
        alignItems: "center", justifyContent: "center", padding: 16,
        background: bgColor }}
    >
      {/* Heaven rays (mythic) */}
      {tier === "mythic" && (
        <div style={{ position: "absolute", inset: 0, overflow: "hidden", pointerEvents: "none" }}>
          {Array.from({ length: 12 }).map((_, i) => (
            <div key={i} style={{
              position: "absolute", left: "50%", top: "50%", transformOrigin: "top",
              width: 4, height: "120vh",
              transform: `translate(-50%, -100%) rotate(${(i/12)*360}deg)`,
              background: "linear-gradient(to bottom, rgba(240,220,120,0.6), transparent)",
              animation: `cpo-heaven-ray 1.2s ease-out ${i*0.05}s both, cpo-spin-slow 14s linear ${1.2+i*0.05}s infinite`,
            }} />
          ))}
        </div>
      )}

      {/* Conic spotlight (epic+) */}
      {isFancy && (
        <div className="cpo-spin-slow" style={{ position: "absolute", inset: 0, pointerEvents: "none",
          background: `conic-gradient(from 0deg at 50% 50%, transparent 0deg, ${meta.color} 4deg, transparent 8deg, transparent 60deg, ${meta.color} 64deg, transparent 68deg, transparent 120deg, ${meta.color} 124deg, transparent 128deg)`,
          opacity: 0.18 }} />
      )}

      {/* Fireworks */}
      {isFancy && (
        <div style={{ position: "absolute", left: "50%", top: "50%", pointerEvents: "none" }}>
          {fireworks.map((f, i) => (
            <div key={i} style={{
              position: "absolute", width: 8, height: 8, borderRadius: "50%",
              background: f.color,
              boxShadow: `0 0 12px ${f.color}, 0 0 24px ${f.color}`,
              "--fx": f.x, "--fy": f.y,
              animation: `cpo-firework 1.2s cubic-bezier(0.1,0.7,0.3,1) ${f.delay}s both`,
            }} />
          ))}
        </div>
      )}

      {/* Bolts */}
      {(tier === "legendary" || tier === "mythic") && (
        <div style={{ position: "absolute", left: "50%", top: "50%", pointerEvents: "none" }}>
          {bolts.map((b, i) => (
            <div key={i} style={{
              position: "absolute", width: 6, height: "60vh",
              background: tier === "mythic"
                ? "linear-gradient(to bottom, transparent, #FFE08A, #FFFFFF, #FF8A3D, transparent)"
                : "linear-gradient(to bottom, transparent, #FFF1B8, #FFD96B, #B8973A, transparent)",
              filter: "blur(1px) drop-shadow(0 0 12px gold)",
              "--bolt-rot": `${b.rot}deg`,
              transformOrigin: "center",
              animation: `cpo-bolt 0.5s ease-out ${b.delay}s both`,
            }} />
          ))}
        </div>
      )}

      {/* Card stage */}
      <div style={{ position: "relative", zIndex: 10, display: "flex",
        flexDirection: "column", alignItems: "center", gap: 24 }}>
        <div className="cpo-float-up" style={{
          textTransform: "uppercase", letterSpacing: "0.4em",
          fontSize: tier === "mythic" ? 22 : 12,
          fontWeight: 700, color: meta.color,
          textShadow: `0 0 20px ${meta.glow}`,
          animationDelay: "0.2s",
        }}>
          {labelText}
        </div>

        {/* 3-D card flip container */}
        <div style={{ perspective: 1200, className: tier === "mythic" && !flipped ? "cpo-mythic-descend" : "" }}>
          <div style={{
            position: "relative", width: 288, height: 384,
            transition: "transform 0.7s",
            transformStyle: "preserve-3d",
            transform: flipped ? "rotateY(180deg)" : "rotateY(0deg)",
          }}>
            {/* Back face */}
            <div style={{
              position: "absolute", inset: 0, borderRadius: 12,
              background: "linear-gradient(135deg, #1a1a22, #0c0c10)",
              border: `2px solid ${meta.color}`,
              backfaceVisibility: "hidden",
              display: "flex", alignItems: "center", justifyContent: "center",
              boxShadow: `0 0 60px ${meta.glow}, inset 0 0 40px ${meta.glow}`,
            }}>
              <div style={{ textAlign: "center" }}>
                <div style={{ fontSize: 72, fontFamily: "Georgia, serif",
                  background: "linear-gradient(135deg, #c9a84c, #7a5e22)",
                  WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent" }}>$</div>
                <div style={{ fontSize: 10, textTransform: "uppercase",
                  letterSpacing: "0.4em", color: "#b8973a" }}>Crypto Holdings</div>
              </div>
              <div style={{ position: "absolute", inset: 12, borderRadius: 8,
                border: `1px solid ${meta.color}60`, pointerEvents: "none" }} />
            </div>

            {/* Front face */}
            <div style={{
              position: "absolute", inset: 0,
              backfaceVisibility: "hidden",
              transform: "rotateY(180deg)",
            }}>
              <CryptoCard crypto={card} size="xl" revealed={flipped} />
            </div>
          </div>
        </div>

        {introDone && !flipped && (
          <button className="cpo-float-up" onClick={() => setFlipped(true)} style={{
            background: "linear-gradient(135deg, #c9a84c, #7a5e22)",
            color: "#0c0c10", fontWeight: 700, fontSize: 16,
            padding: "12px 32px", borderRadius: 8, border: "none",
            cursor: "pointer", letterSpacing: "0.05em",
          }}>
            Reveal Card
          </button>
        )}

        {flipped && (
          <button className="cpo-float-up" onClick={onClose} style={{
            background: "transparent", border: "1px solid #b8973a",
            color: "#b8973a", fontWeight: 700, fontSize: 16,
            padding: "12px 32px", borderRadius: 8, cursor: "pointer",
            letterSpacing: "0.05em", animationDelay: "0.6s",
          }}
            onMouseEnter={e => e.currentTarget.style.background = "rgba(184,151,58,0.1)"}
            onMouseLeave={e => e.currentTarget.style.background = "transparent"}
          >
            Continue Trading
          </button>
        )}
      </div>
    </div>
  );
}

function Collection({ owned }) {
  const totalOwned = Object.values(owned).reduce((a, b) => a + b, 0);
  const uniqueOwned = Object.keys(owned).length;

  return (
    <div style={{ padding: "0 0 32px" }}>
      <div style={{ display: "flex", flexWrap: "wrap", alignItems: "baseline",
        justifyContent: "space-between", gap: 16, marginBottom: 24 }}>
        <h2 style={{ margin: 0, fontFamily: "Georgia, serif", fontSize: 28,
          color: "#f0ece0", letterSpacing: "-0.02em" }}>Your Collection</h2>
        <span style={{ fontSize: 13, color: "#666" }}>
          <strong style={{ color: "#b8973a" }}>{uniqueOwned}</strong> / {CRYPTOS.length} unique ·{" "}
          <strong style={{ color: "#b8973a" }}>{totalOwned}</strong> total
        </span>
      </div>

      {RARITY_ORDER.map(rarity => {
        const items = CRYPTOS.filter(c => c.rarity === rarity);
        const meta = RARITY_META[rarity];
        return (
          <section key={rarity} style={{ marginBottom: 32 }}>
            <div style={{ display: "flex", alignItems: "baseline", gap: 12, marginBottom: 12 }}>
              <h3 style={{ margin: 0, fontSize: 14, fontWeight: 700, textTransform: "uppercase",
                letterSpacing: "0.15em", color: meta.color }}>
                {meta.label}
              </h3>
              <span style={{ fontSize: 11, color: "#555" }}>
                {items.filter(c => owned[c.id]).length}/{items.length} · {(meta.chance*100).toFixed(0)}% drop
              </span>
            </div>
            <div style={{ display: "flex", flexWrap: "wrap", gap: 10 }}>
              {items.map(c => {
                const count = owned[c.id];
                if (!count) return (
                  <div key={c.id} style={{
                    width: 96, height: 128, borderRadius: 12,
                    border: `2px dashed ${meta.color}`,
                    display: "flex", alignItems: "center", justifyContent: "center",
                    fontSize: 28, opacity: 0.3,
                  }}>❓</div>
                );
                return <CryptoCard key={c.id} crypto={c} size="sm" revealed={false} count={count} />;
              })}
            </div>
          </section>
        );
      })}
    </div>
  );
}

// ─── Main exported component ─────────────────────────────────

/**
 * CryptoPackOpener
 *
 * Props:
 *   coins     {number}   – current coin balance (read-only display)
 *   packCost  {number}   – cost to open one pack
 *   onSpend   {Function} – called with (amount) when pack is purchased
 *   onResult  {Function} – called with (card) when a card is rolled
 */
export default function CryptoPackOpener({ coins, packCost = 100, onSpend, onResult }) {
  useEffect(() => { injectCSS(); }, []);

  const [phase, setPhase]     = useState("idle"); // idle | shaking | bursting | reveal
  const [card, setCard]       = useState(null);
  const [owned, setOwned]     = useState({});
  const [activeTab, setTab]   = useState("open"); // open | collection

  const canBuy = coins >= packCost && phase === "idle";

  const open = () => {
    if (!canBuy) return;
    onSpend?.(packCost);
    setPhase("shaking");
    setTimeout(() => setPhase("bursting"), 900);
    setTimeout(() => {
      const result = rollCard();
      setCard(result);
      setOwned(prev => ({ ...prev, [result.id]: (prev[result.id] || 0) + 1 }));
      onResult?.(result);
      setPhase("reveal");
    }, 1500);
  };

  const close = () => {
    setCard(null);
    setPhase("idle");
  };

  const tabStyle = (t) => ({
    padding: "10px 24px",
    borderRadius: 8,
    border: "none",
    fontWeight: 700,
    fontSize: 13,
    textTransform: "uppercase",
    letterSpacing: "0.15em",
    cursor: "pointer",
    transition: "all 0.2s",
    background: activeTab === t
      ? "linear-gradient(135deg, #c9a84c, #7a5e22)"
      : "transparent",
    color: activeTab === t ? "#0c0c10" : "#666",
    borderBottom: activeTab === t ? "none" : "1px solid #222",
  });

  return (
    <div style={{
      minHeight: "100%",
      background: "radial-gradient(ellipse at 50% -10%, rgba(40,35,10,0.5) 0%, #0c0c0e 55%)",
      color: "#f0ece0",
      fontFamily: "ui-sans-serif, system-ui, sans-serif",
      padding: "24px 16px",
    }}>
      {/* Tabs */}
      <div style={{ display: "flex", gap: 4, marginBottom: 32, borderBottom: "1px solid #222" }}>
        <button style={tabStyle("open")}      onClick={() => setTab("open")}>Pack Opener</button>
        <button style={tabStyle("collection")} onClick={() => setTab("collection")}>Collection</button>
      </div>

      {activeTab === "open" && (
        <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 24,
          minHeight: 480, justifyContent: "center" }}>
          {(phase === "idle" || phase === "shaking" || phase === "bursting") && (
            <>
              <PackButton
                onClick={open}
                disabled={!canBuy || phase !== "idle"}
                shaking={phase === "shaking"}
                bursting={phase === "bursting"}
              />
              {phase === "idle" && (
                <>
                  <button
                    onClick={open}
                    disabled={!canBuy}
                    style={{
                      background: canBuy ? "linear-gradient(135deg, #c9a84c, #7a5e22)" : "#333",
                      color: canBuy ? "#0c0c10" : "#555",
                      fontWeight: 700, fontSize: 15,
                      padding: "14px 40px", borderRadius: 8, border: "none",
                      cursor: canBuy ? "pointer" : "not-allowed",
                      textTransform: "uppercase", letterSpacing: "0.2em",
                    }}
                  >
                    Acquire Position — ◈ {packCost}
                  </button>
                  {!canBuy && (
                    <p style={{ fontSize: 11, color: "#555", textTransform: "uppercase",
                      letterSpacing: "0.2em", margin: 0 }}>Insufficient capital</p>
                  )}
                </>
              )}
            </>
          )}
          {phase === "reveal" && card && <RevealOverlay card={card} onClose={close} />}
        </div>
      )}

      {activeTab === "collection" && <Collection owned={owned} />}
    </div>
  );
}

// Also export CRYPTOS and rollCard in case the parent app needs them
export { CRYPTOS, rollCard, RARITY_META };
