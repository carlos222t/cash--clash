+  const level = getLevelFromXP(xp);
+  if (level >= MAX_LEVEL) return 100;
+  const current = getXPForCurrentLevel(xp);
+  const needed = getXPToNextLevel(xp);
+  return (current / needed) * 100;
 }
 
