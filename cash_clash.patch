 // XP & Leveling System
-export const XP_PER_LEVEL = 500;
 export const MAX_LEVEL = 50;
 
+/**
+ * Returns the total XP required to reach a given level.
+ * Level thresholds:
+ *   Levels 1-10:  XP per level increases by 50 starting at 50
+ *                 (50, 100, 150, 200, 250, 300, 350, 400, 450, 500)
+ *   Levels 11-20: increases by 100 (600, 700, 800, ...)
+ *   Levels 21-30: increases by 150 (1150, 1300, 1450, ...)
+ *   Levels 31-40: increases by 200 ...
+ *   Levels 41-50: increases by 250 ...
+ */
+export function getXPRequiredForLevel(level) {
+  if (level <= 1) return 0;
+  let total = 0;
+  for (let l = 1; l < level; l++) {
+    total += getXPForLevelStep(l);
+  }
+  return total;
+}
+
+/** XP needed to go from level l to level l+1 */
+function getXPForLevelStep(l) {
+  // Group of 10 levels determines the increment (+50 per group)
+  const group = Math.floor((l - 1) / 10); // 0-indexed group
+  const posInGroup = ((l - 1) % 10) + 1;  // 1–10 within group
+  const baseIncrement = 50 * (group + 1);  // 50 for group 0, 100 for group 1, etc.
+  return baseIncrement * posInGroup;
+}
+
 export function getLevelFromXP(xp) {
-  return Math.min(Math.floor((xp || 0) / XP_PER_LEVEL) + 1, MAX_LEVEL);
+  const totalXP = xp || 0;
+  let level = 1;
+  while (level < MAX_LEVEL && totalXP >= getXPRequiredForLevel(level + 1)) {
+    level++;
+  }
+  return level;
 }
 
 export function getXPForCurrentLevel(xp) {
-  return (xp || 0) % XP_PER_LEVEL;
+  const level = getLevelFromXP(xp);
+  return (xp || 0) - getXPRequiredForLevel(level);
+}
+
+export function getXPToNextLevel(xp) {
+  const level = getLevelFromXP(xp);
+  if (level >= MAX_LEVEL) return 0;
+  return getXPRequiredForLevel(level + 1) - getXPRequiredForLevel(level);
 }
 
